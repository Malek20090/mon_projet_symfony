{% extends 'admin/layout.html.twig' %}

{% block title %}{{ action }} – Real Case | Decide${% endblock %}

{% block content %}
<div class="admin-page">
    <div class="page-header-card">
        <div>
            <h1>Real Case – {{ action }}</h1>
            <p class="mb-0">{% if action == 'Add' %}Create une nouvelle demande{% else %}Edit la demande{% endif %}</p>
        </div>
    </div>

    {% if errors is defined and errors is not empty %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Errors de validation</strong>
            <ul class="mb-0 mt-2">
                {% for field, error in errors %}
                    <li>{{ error }}</li>
                {% endfor %}
            </ul>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endif %}

    <div class="card-custom">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h5 class="mb-4"><i class="fas fa-file-alt text-primary me-2"></i>Formulaire Real Case</h5>
                <form method="POST" id="casrellesForm">
                    <input type="hidden" name="_token" value="{{ csrf_token('casrelles_form') }}">

                    <div class="mb-3">
                        <label for="titre" class="form-label fw-bold">Titre <span class="text-danger">*</span></label>
                        <input type="text" class="form-control {% if errors.titre is defined %}is-invalid{% endif %}"
                               id="titre" name="titre" value="{{ cas.titre ?? '' }}"
                               placeholder="Entrez le titre du cas" maxlength="150" required>
                        {% if errors.titre is defined %}
                            <div class="invalid-feedback">{{ errors.titre }}</div>
                        {% endif %}
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="type" class="form-label fw-bold">Type <span class="text-danger">*</span></label>
                            <select class="form-select {% if errors.type is defined %}is-invalid{% endif %}" id="type" name="type" required>
                                <option value="">Select...</option>
                                <option value="POSITIF" {% if cas.type == 'POSITIF' %}selected{% endif %}>Positive (+)</option>
                                <option value="NEGATIF" {% if cas.type == 'NEGATIF' %}selected{% endif %}>Negative (-)</option>
                            </select>
                            {% if errors.type is defined %}
                                <div class="invalid-feedback">{{ errors.type }}</div>
                            {% endif %}
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="montant" class="form-label fw-bold">Montant (DT) <span class="text-danger">*</span></label>
                            <input type="number" class="form-control {% if errors.montant is defined %}is-invalid{% endif %}"
                                   id="montant" name="montant" value="{{ cas.montant ?? '' }}"
                                   placeholder="0.00" min="0" step="0.01" required>
                            {% if errors.montant is defined %}
                                <div class="invalid-feedback">{{ errors.montant }}</div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="solution" class="form-label fw-bold">Solution <span class="text-danger">*</span></label>
                        <select class="form-select {% if errors.solution is defined %}is-invalid{% endif %}" id="solution" name="solution" required>
                            <option value="">Select...</option>
                            <option value="FONDS_SECURITE" {% if cas.solution == 'FONDS_SECURITE' %}selected{% endif %}>Emergency Fund</option>
                            <option value="OBJECTIF" {% if cas.solution == 'OBJECTIF' or cas.solution == 'EPARGNE' %}selected{% endif %}>Objectif</option>
                            <option value="FAMILLE" {% if cas.solution == 'FAMILLE' %}selected{% endif %}>Famille</option>
                        </select>
                        {% if errors.solution is defined %}
                            <div class="invalid-feedback">{{ errors.solution }}</div>
                        {% endif %}
                    </div>

                    <div class="mb-3">
                        <label for="financial_goal_id" class="form-label">Financial goal</label>
                        <select class="form-select {% if errors.financial_goal_id is defined %}is-invalid{% endif %}" id="financial_goal_id" name="financial_goal_id">
                            <option value="">Select un financial goal (optionnel)</option>
                            {% for goal in financialGoals|default([]) %}
                                <option value="{{ goal.id }}" {% if cas.financialGoal and cas.financialGoal.id == goal.id %}selected{% endif %}>
                                    {{ goal.nom }} - Cible: {{ goal.montantCible|default(0)|number_format(2, ',', ' ') }} DT
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.financial_goal_id is defined %}
                            <div class="invalid-feedback">{{ errors.financial_goal_id }}</div>
                        {% endif %}
                    </div>

                    <div class="mb-3">
                        <label for="dateEffet" class="form-label fw-bold">Date d'effet <span class="text-danger">*</span></label>
                        <input type="date" class="form-control {% if errors.dateEffet is defined %}is-invalid{% endif %}"
                               id="dateEffet" name="dateEffet" value="{{ cas.dateEffet ? cas.dateEffet|date('Y-m-d') : '' }}" required>
                        {% if errors.dateEffet is defined %}
                            <div class="invalid-feedback">{{ errors.dateEffet }}</div>
                        {% endif %}
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control {% if errors.description is defined %}is-invalid{% endif %}"
                                  id="description" name="description" rows="4" placeholder="Description (optionnel)">{{ cas.description ?? '' }}</textarea>
                        {% if errors.description is defined %}
                            <div class="invalid-feedback">{{ errors.description }}</div>
                        {% endif %}
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>{{ action }}</button>
                        <a href="{{ path('admin_casrelles_list') }}" class="btn btn-secondary"><i class="fas fa-arrow-left me-2"></i>Back to list</a>
                    </div>
                </form>
                <div class="admin-page-footer mt-4">
                    <a href="{{ path('admin_index') }}" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Back to dashboard</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
