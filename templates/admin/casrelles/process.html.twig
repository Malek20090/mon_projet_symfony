{% extends 'admin/layout.html.twig' %}

{% block title %}Process request | Decide${% endblock %}

{% block content %}
<div class="admin-page">
    <div class="page-header-card">
        <div>
            <h1>Process request</h1>
            <p class="mb-0">Accept or reject request - Real Case</p>
        </div>
        <a href="{{ path('admin_casrelles_list') }}" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-2"></i>Back to list</a>
    </div>

    <div class="card-custom">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="fas fa-file-alt me-2 text-primary"></i>Request details</h5>
                    </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <td><strong>Titre:</strong></td>
                            <td>{{ cas.titre }}</td>
                        </tr>
                        <tr>
                            <td><strong>Type</strong></td>
                            <td>
                                {% if cas.type == 'POSITIF' %}
                                    <span class="badge bg-success">POSITIF</span>
                                {% else %}
                                    <span class="badge bg-danger">NEGATIVE</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Montant:</strong></td>
                            <td class="h4 {% if cas.type == 'POSITIF' %}text-success{% else %}text-danger{% endif %}">
                                {{ cas.montant }} DT
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Date:</strong></td>
                            <td>{{ cas.dateEffet|date('d/m/Y H:i') }}</td>
                        </tr>
                        <tr>
                            <td><strong>Solution:</strong></td>
                            <td>
                                {% if cas.solution == 'FONDS_SECURITE' %}
                                    <span class="badge bg-info"><i class="fas fa-shield-alt me-1"></i>Emergency Fund</span>
                                {% elseif cas.solution == 'OBJECTIF' or cas.solution == 'EPARGNE' %}
                                    <span class="badge bg-warning"><i class="fas fa-bullseye me-1"></i>Objectif</span>
                                {% elseif cas.solution == 'FAMILLE' %}
                                    <span class="badge bg-secondary"><i class="fas fa-users me-1"></i>Famille</span>
                                {% else %}
                                    <span class="badge bg-light text-dark">{{ cas.solution }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% if cas.resultat %}
                        <tr>
                            <td><strong>Statut:</strong></td>
                            <td>
                                {% if cas.resultat == 'VALIDE' %}
                                    <span class="badge bg-success">Accepted</span>
                                {% elseif cas.resultat == 'REFUSE' %}
                                    <span class="badge bg-danger">Rejected</span>
                                {% else %}
                                    <span class="badge bg-warning">En attente</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endif %}
                        {% if cas.raisonRefus %}
                        <tr>
                            <td><strong>Reason for rejection:</strong></td>
                            <td class="text-danger">{{ cas.raisonRefus }}</td>
                        </tr>
                        {% endif %}
                    </table>
                </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header text-white" style="background: linear-gradient(135deg, #0ea5e9, #0284c7);">
                        <h5 class="mb-0"><i class="fas fa-shield-alt me-2"></i>Emergency fund</h5>
                    </div>
                    <div class="card-body text-center py-4">
                        <div class="h3 mb-1 text-primary">{{ securityFund|number_format(2, ',', ' ') }} DT</div>
                        <p class="text-muted mb-0 small">Current emergency fund balance</p>
                    </div>
                </div>

                {% if (cas.solution == 'OBJECTIF' or cas.solution == 'EPARGNE') and cas.financialGoal %}
                <div class="card mb-4">
                    <div class="card-header text-dark" style="background: #fef3c7; border-bottom-color: #fcd34d;">
                        <h5 class="mb-0"><i class="fas fa-bullseye me-2"></i>Financial goal</h5>
                    </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <td><strong>Nom:</strong></td>
                            <td>{{ cas.financialGoal.nom }}</td>
                        </tr>
                        <tr>
                            <td><strong>Montant cible:</strong></td>
                            <td>{{ cas.financialGoal.montantCible|number_format(2, ',', ' ') }} DT</td>
                        </tr>
                        <tr>
                            <td><strong>Montant actuel:</strong></td>
                            {% set objectifCurrent = casObjectifCurrent ?? 0 %}
                            <td class="{% if cas.type == 'NEGATIF' and objectifCurrent < cas.montant %}text-danger{% else %}text-success{% endif %}">
                                {{ objectifCurrent|number_format(2, ',', ' ') }} DT
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Created on:</strong></td>
                            <td>{{ cas.dateEffet ? cas.dateEffet|date('d/m/Y') : '-' }}</td>
                        </tr>
                        {% if cas.type == 'NEGATIF' %}
                        <tr>
                            <td><strong>After transaction:</strong></td>
                            <td class="text-primary">
                                {{ (objectifCurrent - cas.montant)|number_format(2, ',', ' ') }} DT
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td><strong>After transaction:</strong></td>
                            <td class="text-primary">
                                {{ (objectifCurrent + cas.montant)|number_format(2, ',', ' ') }} DT
                            </td>
                        </tr>
                        {% endif %}
                    </table>
                </div>
                </div>
                {% endif %}
            </div>

            <div class="col-lg-6">
                {% if cas.resultat == 'EN_ATTENTE' %}
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="fas fa-tasks me-2 text-primary"></i>Actions</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">The request is pending validation.</p>
                        <div class="alert alert-info mb-0 border-0">
                            <i class="fas fa-info-circle me-2"></i>
                            By accepting, transactions will be automatically executed on the savings account or emergency fund.
                        </div>
                        <div class="alert alert-light border mt-3 mb-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong><i class="fas fa-robot me-2 text-primary"></i>AI Decision Proposal</strong>
                                <button
                                    type="button"
                                    class="btn btn-sm btn-outline-primary"
                                    id="generateAiProposalBtn"
                                    data-url="{{ path('admin_casrelles_ai_decision_proposal', { id: cas.id }) }}"
                                >
                                    Generate proposal
                                </button>
                            </div>
                            <div id="aiProposalResult" class="small text-muted mt-2">
                                Click "Generate proposal" to get an intelligent recommendation.
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <form method="POST" class="d-flex flex-column gap-2">
                            <button type="submit" name="action" value="accept" class="btn btn-success" onclick="return confirm('Confirmer la validation de cette demande ?');">
                                <i class="fas fa-check me-2"></i>Accept request
                            </button>
                            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">
                                <i class="fas fa-times me-2"></i>Reject request
                            </button>
                            <a href="{{ path('admin_casrelles_list') }}" class="btn btn-outline-secondary">Annuler</a>
                        </form>
                    </div>
                </div>
                {% else %}
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Request already processed</h5>
                    </div>
                <div class="card-body text-center">
                    {% if cas.resultat == 'VALIDE' %}
                        <i class="fas fa-check-circle text-success fa-4x mb-3"></i>
                        <h4 class="text-success">Demande Accepted</h4>
                        <p>The request was processed successfully.</p>
                        {% if (cas.solution == 'OBJECTIF' or cas.solution == 'EPARGNE') and cas.financialGoal %}
                            <div class="alert alert-success">
                                <strong>Financial goal: {{ cas.financialGoal.nom }}</strong><br>
                                {% if cas.type == 'NEGATIF' %}
                                    {{ cas.montant }} DT were used<br>
                                {% else %}
                                    {{ cas.montant }} DT were added<br>
                                {% endif %}
                                Current amount: {{ (casObjectifCurrent ?? 0)|number_format(2, ',', ' ') }} DT
                            </div>
                        {% elseif cas.solution == 'FONDS_SECURITE' %}
                            <div class="alert alert-info">
                                {% if cas.type == 'NEGATIF' %}
                                    <strong>{{ cas.montant }} DT</strong> were withdrawn from the emergency fund
                                {% else %}
                                    <strong>{{ cas.montant }} DT</strong> were added to the emergency fund
                                {% endif %}
                            </div>
                        {% elseif cas.solution == 'FAMILLE' %}
                            <div class="alert alert-secondary">
                                <i class="fas fa-users me-2"></i>Family asked for help
                            </div>
                        {% endif %}
                    {% else %}
                        <i class="fas fa-times-circle text-danger fa-4x mb-3"></i>
                        <h4 class="text-danger">Demande Rejected</h4>
                        {% if cas.raisonRefus %}
                            <div class="alert alert-danger">
                                <strong>Reason for rejection:</strong><br>
                                {{ cas.raisonRefus }}
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
                    <div class="card-footer">
                        <a href="{{ path('admin_casrelles_list') }}" class="btn btn-primary">
                            <i class="fas fa-arrow-left me-2"></i>Back to list
                        </a>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="admin-page-footer">
        <a href="{{ path('admin_casrelles_list') }}" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-2"></i>Back to list</a>
        <a href="{{ path('admin_index') }}" class="btn btn-outline-secondary"><i class="fas fa-home me-2"></i>Dashboard</a>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-times-circle me-2"></i>Reject request</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="raisonRefus" class="form-label fw-bold">Rejection reason:</label>
                        <div class="d-flex justify-content-end mb-2">
                            <button
                                type="button"
                                class="btn btn-sm btn-outline-primary"
                                id="generateAiReasonBtn"
                                data-url="{{ path('admin_casrelles_ai_refusal_reason', { id: cas.id }) }}"
                            >
                                <i class="fas fa-robot me-1"></i>Generate with AI
                            </button>
                        </div>
                        <textarea class="form-control" id="raisonRefus" name="raisonRefus" rows="4" 
                                  placeholder="Please provide the reason for rejection..." required></textarea>
                        <div class="form-text">This reason will be communicated to the user.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" name="action" value="reject" class="btn btn-danger">
                        <i class="fas fa-times me-2"></i>Confirm rejection
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function () {
            const btn = document.getElementById('generateAiReasonBtn');
            const proposalBtn = document.getElementById('generateAiProposalBtn');
            const textarea = document.getElementById('raisonRefus');
            const proposalBox = document.getElementById('aiProposalResult');
            if (!btn || !textarea) return;

            btn.addEventListener('click', async function () {
                const url = btn.dataset.url;
                if (!url) return;

                const originalHtml = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating...';

                try {
                    const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    const data = await response.json();
                    if (data.success && data.reason) {
                        textarea.value = data.reason;
                    } else {
                        alert(data.message || 'AI generation failed.');
                    }
                } catch (e) {
                    alert('Network error while generating AI reason.');
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            });

            if (!proposalBtn || !proposalBox) return;
            proposalBtn.addEventListener('click', async function () {
                const url = proposalBtn.dataset.url;
                if (!url) return;

                const originalHtml = proposalBtn.innerHTML;
                proposalBtn.disabled = true;
                proposalBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating...';

                try {
                    const response = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                    const data = await response.json();
                    if (data.success && data.proposal) {
                        const p = data.proposal;
                        proposalBox.innerHTML =
                            '<div><strong>Recommended action:</strong> ' + (p.recommended_action || '-') + '</div>' +
                            '<div><strong>Recommended solution:</strong> ' + (p.recommended_solution || '-') + '</div>' +
                            '<div><strong>Confidence:</strong> ' + (p.confidence || 0) + '%</div>' +
                            '<div class="mt-1"><strong>Rationale:</strong> ' + (p.rationale || '-') + '</div>';

                        if (p.recommended_action === 'reject' && p.refusal_reason && !textarea.value.trim()) {
                            textarea.value = p.refusal_reason;
                        }
                    } else {
                        proposalBox.textContent = data.message || 'AI proposal failed.';
                    }
                } catch (e) {
                    proposalBox.textContent = 'Network error while generating AI proposal.';
                } finally {
                    proposalBtn.disabled = false;
                    proposalBtn.innerHTML = originalHtml;
                }
            });
        })();
    </script>
{% endblock %}
