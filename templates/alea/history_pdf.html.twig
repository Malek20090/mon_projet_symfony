<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: DejaVu Sans, Arial, sans-serif; font-size: 12px; color: #222; }
        h1 { margin: 0 0 8px; font-size: 22px; }
        .meta { margin-bottom: 14px; color: #555; }
        .grid { width: 100%; margin-bottom: 14px; border-collapse: collapse; }
        .grid td { border: 1px solid #ddd; padding: 8px; }
        .label { color: #666; font-size: 11px; }
        .value { font-weight: bold; font-size: 14px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ddd; padding: 7px; text-align: left; }
        th { background: #f3f3f3; }
        .gain { color: #198754; font-weight: bold; }
        .expense { color: #dc3545; font-weight: bold; }
    </style>
</head>
<body>
    <h1>Real Cases History Report</h1>
    <div class="meta">Generated on {{ generatedAt|date('d/m/Y H:i') }}</div>

    <table class="grid">
        <tr>
            <td>
                <div class="label">Total Cases</div>
                <div class="value">{{ stats.count }}</div>
            </td>
            <td>
                <div class="label">Total Gains</div>
                <div class="value">+{{ stats.totalPositif|number_format(2, ',', ' ') }} DT</div>
            </td>
            <td>
                <div class="label">Total Expenses</div>
                <div class="value">-{{ stats.totalNegatif|number_format(2, ',', ' ') }} DT</div>
            </td>
            <td>
                <div class="label">Net</div>
                <div class="value">{{ stats.totalNet|number_format(2, ',', ' ') }} DT</div>
            </td>
        </tr>
    </table>

    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Title</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Solution</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            {% for c in cas %}
                <tr>
                    <td>{{ c.dateEffet ? c.dateEffet|date('d/m/Y') : '-' }}</td>
                    <td>{{ c.titre }}</td>
                    <td>{{ c.type }}</td>
                    <td class="{% if c.type == 'POSITIF' %}gain{% else %}expense{% endif %}">
                        {% if c.type == 'POSITIF' %}+{% else %}-{% endif %}{{ c.montant|number_format(2, ',', ' ') }} DT
                    </td>
                    <td>{{ c.solution }}</td>
                    <td>{{ c.resultat ?? 'EN_ATTENTE' }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6">No real case found.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
