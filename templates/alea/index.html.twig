{# Same appearance as Savings, Contact, Service â€” base_pages = glass-nav + footer-decides #}
{% extends 'base_pages.html.twig' %}

{% block title %}Unexpected Events & Real Cases | Decide${% endblock %}

{% block body_class %}alea-page{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .alea-panel {
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            background: #fff;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        }
        .section-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            font-weight: 800;
            letter-spacing: .06em;
            color: #1d4ed8;
            text-transform: uppercase;
            background: #eff6ff;
            border: 1px solid #dbeafe;
            border-radius: 999px;
            padding: 5px 12px;
            margin-bottom: 10px;
        }
        .event-list-shell .list-group-item.bg-light {
            position: sticky;
            top: 0;
            z-index: 1;
        }
        .decision-shell .event-headline {
            font-size: 11px;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: #64748b;
            font-weight: 700;
        }
        .decision-shell .event-title {
            font-size: clamp(1.2rem, 2vw, 1.7rem);
            font-weight: 800;
            line-height: 1.2;
            margin: 0;
        }
        .helper-note {
            font-size: 12px;
            color: #64748b;
            margin-top: 8px;
        }
        /* Custom styles for +/- logic */
        .clickable-item {
            cursor: pointer;
            transition: all 0.3s;
            border-left: 4px solid transparent;
        }
        .clickable-item:hover {
            background-color: #e9ecef;
            transform: translateX(5px);
        }
        
        /* Negative theme */
        .item-negative { border-left-color: #dc3545; }
        .theme-negative .card-header-icon { color: #dc3545; background-color: rgba(220, 53, 69, 0.1); }
        .theme-negative .amount-text { color: #dc3545; }
        
        /* Positive theme */
        .item-positive { border-left-color: #198754; }
        .theme-positive .card-header-icon { color: #198754; background-color: rgba(25, 135, 84, 0.1); }
        .theme-positive .amount-text { color: #198754; }

        .choice-btn { text-align: left; position: relative; transition: 0.3s; }
        .choice-btn:hover { background-color: #f8f9fa; border-color: #0d6efd; }
        
        /* Savings cards */
        .epargne-card {
            border: 2px solid #dee2e6;
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .epargne-card:hover {
            border-color: #0d6efd;
            background-color: #f8f9fa;
        }
        .epargne-card.selected {
            border-color: #0d6efd;
            background-color: rgba(13, 110, 253, 0.1);
        }
        .epargne-card.disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        .epargne-balance {
            font-size: 1.2em;
            font-weight: bold;
        }
        .epargne-date {
            font-size: 0.85em;
            color: #6c757d;
        }

        .ai-section-header {
            background: linear-gradient(135deg, #e0f2fe, #dbeafe);
            border: 1px solid #bfdbfe;
            color: #1e3a8a;
        }

        .google-tools-card {
            border: 1px solid #dbeafe;
            background: linear-gradient(180deg, #ffffff, #f8fbff);
        }

        .google-action-btn {
            border-width: 1.5px;
            font-weight: 600;
        }

        #googleToolsStatus {
            min-height: 22px;
            font-weight: 600;
            color: #1d4ed8;
        }

        .nearby-list .nearby-card {
            border: 1px solid #e2e8f0;
            border-left: 4px solid #60a5fa;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 10px;
            background: #fff;
            box-shadow: 0 4px 14px rgba(15, 23, 42, 0.06);
        }

        .nearby-list .nearby-name {
            font-weight: 700;
            color: #0f172a;
        }

        .nearby-list .nearby-type {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 700;
            color: #1d4ed8;
            background: #dbeafe;
            border-radius: 999px;
            padding: 2px 10px;
            margin-top: 6px;
        }
    </style>
{% endblock %}

{% block body %}
    <!-- Hero (same style as Savings â€” blue gradient, breadcrumbs, actions) -->
    <section class="hero">
        <div class="container text-center wrap">
            <h1>Unexpected Events & Real Cases</h1>
            <p>Unexpected events management and real-case simulation â€” run simulations and submit your requests.</p>
            <div class="breadcrumbs">
                <a href="{{ path('app_home') }}">Home</a> / <a href="{{ path('app_service') }}">Modules</a> / <span class="active">Unexpected Events & Real Cases</span>
            </div>
            <div class="hero-actions">
                <a class="btn-soft" href="#customEventForm">Add a case</a>
                <a class="btn-soft" href="{{ path('imprevu_history') }}">
        📜 My History
    </a>

            </div>
        </div>
    </section>

    <!-- Main content -->
    <section class="container py-5">
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="bg-white rounded p-4 shadow-sm text-center border-bottom border-primary border-3">
                        <i class="fas fa-university text-primary fa-2x mb-2"></i>
                        <h6>Total Objectifs</h6>
                        <h3 class="text-dark">{{ objectifs|default([])|length }} objectifs</h3>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="bg-white rounded p-4 shadow-sm text-center border-bottom border-success border-3">
                        <i class="fas fa-shield-alt text-success fa-2x mb-2"></i>
                        <h6>Emergency Fund</h6>
                        <h3 class="text-success">{{ securityFund|number_format(2, ',', ' ') }} DT</h3>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="bg-white rounded p-4 shadow-sm text-center border-bottom border-danger border-3">
                        <i class="fas fa-heartbeat text-danger fa-2x mb-2"></i>
                        <h6>Resilience Score</h6>
                        <h3 class="text-danger">85/100</h3>
                    </div>
                </div>
            </div>

            {% if refusalPopup %}
                <div class="alert alert-danger d-flex justify-content-between align-items-start shadow-sm mb-4" role="alert">
                    <div>
                        <strong><i class="fas fa-bell me-2"></i>{{ refusalPopup.title|default('Notification de refus') }}</strong>
                        <div class="mt-1">{{ refusalPopup.message|default('Votre demande a ete refusee.') }}</div>
                        {% if refusalPopup.createdAt %}
                            <small class="text-muted d-block mt-1">Traitee le : {{ refusalPopup.createdAt|date('d/m/Y H:i') }}</small>
                        {% endif %}
                    </div>
                    <a href="{{ path('imprevu_history') }}" class="btn btn-sm btn-outline-danger ms-3">Voir historique</a>
                </div>
            {% endif %}

            <div class="row g-5">
                <!-- Left Panel -->
                <div class="col-lg-5">
                    <!-- Add un Real Case -->
                    <div class="alea-panel p-4 mb-4">
                        <div class="section-kicker"><i class="fas fa-plus-circle"></i>New Case</div>
                        <h5 class="mb-3">Add a Real Case</h5>
                        <form id="customEventForm">
                            <div class="mb-2">
                                <input type="text" id="customTitle" class="form-control" placeholder="Titre">
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <select id="customType" class="form-select">
                                        <option value="" selected>Auto-detect (+/-)</option>
                                        <option value="NEGATIF">Expense (-)</option>
                                        <option value="POSITIF">Gain (+)</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <input type="number" id="customAmount" class="form-control" placeholder="Montant (DT)">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="customJustificatif" class="form-label mb-1">Justificatif (optionnel)</label>
                                <input type="file" id="customJustificatif" class="form-control" accept=".pdf,.png,.jpg,.jpeg">
                            </div>
                            <div class="mb-3">
                                <textarea id="customDescription" class="form-control" rows="2" placeholder="Description libre (optionnel)"></textarea>
                            </div>
                            <button type="button" id="voiceCaseBtn" class="btn btn-outline-secondary w-100 btn-sm mb-2" onclick="startVoiceCaseInput()">
                                <i class="fas fa-microphone me-2"></i>Parler (titre + montant + plus/moins)
                            </button>
                            <div id="voiceCaseStatus" class="small text-muted mb-2 d-none"></div>
                            <button type="button" onclick="addCustomEvent()" class="btn btn-primary w-100 btn-sm">Choisir ce cas</button>
                            <div class="helper-note">Tip: ex. "fuite salle de bain moins 180" ou "prime plus 350".</div>
                        </form>
                    </div>

                    <!-- Unexpected Events Possibles -->
                    <div class="alea-panel event-list-shell p-3">
                    <h5 class="mb-3 mt-1">Possible unexpected events (database)</h5>
                    <div class="list-group shadow-sm rounded-3 overflow-hidden">
                        <!-- Risques -->
                        <div class="list-group-item bg-light fw-bold text-danger">
                            <i class="fas fa-arrow-down me-2"></i>Risques (-)
                        </div>
                        {% for impr in imprevus %}
                            {% if impr.type == 'NEGATIF' %}
                                <div class="list-group-item list-group-item-action clickable-item item-negative p-3" 
                                     onclick="loadEvent('NEGATIF', '{{ impr.titre|escape('js') }}', {{ impr.budget }}, '{{ impr.messageEducatif|default('Description')|escape('js') }}')">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span><i class="fas fa-exclamation-triangle text-muted me-2"></i>{{ impr.titre }}</span>
                                        <span class="fw-bold text-danger">-{{ impr.budget }} DT</span>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}


                        <!-- Opportunities -->
                        <div class="list-group-item bg-light fw-bold text-success mt-2">
                            <i class="fas fa-arrow-up me-2"></i>Opportunities (+)
                        </div>
                        {% for impr in imprevus %}
                            {% if impr.type == 'POSITIF' %}
                                <div class="list-group-item list-group-item-action clickable-item item-positive p-3" 
                                     onclick="loadEvent('POSITIF', '{{ impr.titre|escape('js') }}', {{ impr.budget }}, '{{ impr.messageEducatif|default('Description')|escape('js') }}')">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span><i class="fas fa-gift text-muted me-2"></i>{{ impr.titre }}</span>
                                        <span class="fw-bold text-success">+{{ impr.budget }} DT</span>
                                    </div>
                                </div>
                            {% endif %}
                        {% endfor %}


                        {% if aiRiskInsights.suggestedIncidents is not empty or aiRiskInsights.suggestedOpportunities is not empty %}
                            <div class="list-group-item fw-bold ai-section-header mt-2">
                                <i class="fas fa-robot me-2"></i>Generated by AI from repeated cases
                            </div>

                            {% for item in aiRiskInsights.suggestedIncidents %}
                                <div class="list-group-item list-group-item-action clickable-item item-negative p-3"
                                     onclick="loadEvent('NEGATIF', '{{ item|escape('js') }}', 120, 'Suggestion IA basee sur repetition des incidents.')">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span><i class="fas fa-brain text-muted me-2"></i>{{ item }}</span>
                                        <span class="fw-bold text-danger">-120 DT</span>
                                    </div>
                                </div>
                            {% endfor %}

                            {% for item in aiRiskInsights.suggestedOpportunities %}
                                <div class="list-group-item list-group-item-action clickable-item item-positive p-3"
                                     onclick="loadEvent('POSITIF', '{{ item|escape('js') }}', 80, 'Opportunite preventive generee par IA selon votre historique.')">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span><i class="fas fa-lightbulb text-muted me-2"></i>{{ item }}</span>
                                        <span class="fw-bold text-success">+80 DT</span>
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                    </div>

                </div>

                <!-- Right Panel / Decision -->
                <div class="col-lg-7">
                    <div id="decisionPanel" class="alea-panel decision-shell p-5 theme-negative">
                        <div class="d-flex align-items-center mb-4">
                            <div class="btn-lg-square rounded-circle me-3 card-header-icon d-flex align-items-center justify-content-center" style="width:60px;height:60px;">
                                <i id="eventIcon" class="fas fa-exclamation-triangle fa-2x"></i>
                            </div>
                            <div>
                                <div class="event-headline">Selected Case</div>
                                <h2 id="eventTitle" class="event-title">Select a case...</h2>
                            </div>
                        </div>
                        <div class="p-4 border rounded bg-light mb-4">
                            <p id="eventDesc" class="lead mb-3">Click an event on the left.</p>
                            <hr>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fs-5">Impact Financier :</span>
                                <span id="eventAmount" class="display-6 fw-bold amount-text">---</span>
                            </div>
                        </div>
                        
                        <!-- Options pour CAS NEGATIF -->
                        <div id="negativeOptions" class="d-none">
                            <h5 class="mb-3">How would you like to handle this expense?</h5>
                            
                            <!-- Option 1: Emergency Fund -->
                            <button class="btn btn-light border w-100 p-3 mb-2 choice-btn solution-btn" data-solution="FONDS_SECURITE" onclick="selectSolution(this)">
                                <i class="fas fa-shield-alt text-primary me-3 fa-lg"></i>
                                <strong>Utiliser Emergency Fund</strong>
                                <span class="text-muted float-end">{{ securityFund|number_format(2, ',', ' ') }} DT</span>
                            </button>
                            
                            <!-- Option 2: Use savings -->
                            <button class="btn btn-light border w-100 p-3 mb-2 choice-btn solution-btn" data-solution="OBJECTIF" onclick="selectSolution(this)">
                                <i class="fas fa-bullseye text-warning me-3 fa-lg"></i>
                                <strong>Use objectif</strong>
                            </button>
                            
                            <!-- Option 3: Famille -->
                            <button class="btn btn-light border w-100 p-3 mb-2 choice-btn solution-btn" data-solution="FAMILLE" onclick="selectSolution(this)">
                                <i class="fas fa-users text-info me-3 fa-lg"></i>
                                <strong>Ask family</strong>
                            </button>
                            
                            <!-- Section de savings selection (hidden by default) -->
                            <div id="epargneSelection" class="mt-3 p-3 border rounded bg-white d-none">
                                <h6 class="mb-3"><i class="fas fa-bullseye text-warning me-2"></i>Select objectif:</h6>
                                {% for objectif in objectifs|default([]) %}
                                    {% set hasEnough = objectif.current >= 0 %}
                                    <div class="epargne-card {% if not hasEnough %}disabled{% endif %}" 
                                         data-id="{{ objectif.id }}" 
                                         data-balance="{{ objectif.current }}"
                                         onclick="selectEpargne(this)"
                                         {% if not hasEnough %}style="opacity:0.5;cursor:not-allowed;"{% endif %}>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <div class="fw-bold">{{ objectif.name }}</div>
                                                <div class="epargne-date">Target: {{ objectif.target|number_format(2, ',', ' ') }} DT</div>
                                            </div>
                                            <div class="epargne-balance {% if objectif.current < currentAmount|default(0) %}text-danger{% else %}text-success{% endif %}">
                                                {{ objectif.current|number_format(2, ',', ' ') }} DT
                                            </div>
                                        </div>
                                    </div>
                                {% else %}
                                    <div class="text-muted text-center py-3">
                                        <i class="fas fa-info-circle me-2"></i>
                                        No objectif available
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                        
                        <!-- Options pour CAS POSITIF -->
                        <div id="positiveOptions" class="d-none">
                            <h5 class="mb-3">How would you like to use this gain?</h5>
                            
                            <!-- Option 1: Renforcer Emergency Fund -->
                            <button class="btn btn-light border w-100 p-3 mb-2 choice-btn solution-btn" data-solution="FONDS_SECURITE" onclick="selectSolution(this)">
                                <i class="fas fa-shield-alt text-success me-3 fa-lg"></i>
                                <strong>Renforcer Emergency Fund</strong>
                                <span class="text-muted float-end">{{ securityFund|number_format(2, ',', ' ') }} DT</span>
                            </button>
                            
                            <!-- Option 2: Add to savings -->
                            <button class="btn btn-light border w-100 p-3 mb-2 choice-btn solution-btn" data-solution="OBJECTIF" onclick="selectSolution(this)">
                                <i class="fas fa-bullseye text-warning me-3 fa-lg"></i>
                                <strong>Add to objectif</strong>
                            </button>
                            
                            <!-- Section de savings selection (hidden by default) -->
                            <div id="epargneSelectionPos" class="mt-3 p-3 border rounded bg-white d-none">
                                <h6 class="mb-3"><i class="fas fa-bullseye text-warning me-2"></i>Select objectif:</h6>
                                {% for objectif in objectifs|default([]) %}
                                    <div class="epargne-card" data-id="{{ objectif.id }}" data-balance="{{ objectif.current }}" onclick="selectEpargnePos(this)">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <div class="fw-bold">{{ objectif.name }}</div>
                                                <div class="epargne-date">Target: {{ objectif.target|number_format(2, ',', ' ') }} DT</div>
                                            </div>
                                            <div class="epargne-balance text-success">
                                                {{ objectif.current|number_format(2, ',', ' ') }} DT
                                            </div>
                                        </div>
                                    </div>
                                {% else %}
                                    <div class="text-muted text-center py-3">
                                        <i class="fas fa-info-circle me-2"></i>
                                        No objectif available
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                        
                        <!-- Confirm button -->
                        <div id="submitSection" class="mt-4 d-none">
                            <button type="button" onclick="submitRequest()" class="btn btn-primary w-100 py-3">
                                <i class="fas fa-paper-plane me-2"></i>Send request
                            </button>
                        </div>
                    </div>

                    <div class="rounded p-4 shadow-sm mt-4 google-tools-card">
                        <h6 class="mb-3"><i class="fas fa-map-marker-alt text-primary me-2"></i>Smart Nearby Assistant</h6>
                        <p class="text-muted small mb-3">Select a case, then find contextual places or create a reminder.</p>
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-outline-primary btn-sm google-action-btn" onclick="createGoogleCalendarReminder()">
                                <i class="fas fa-calendar-plus me-2"></i>Add reminder to Google Calendar
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm google-action-btn" onclick="findNearbyServices()">
                                <i class="fas fa-map me-2"></i>Find matching nearby services
                            </button>
                        </div>
                        <div id="googleToolsStatus" class="small mt-3"></div>
                        <div id="nearbyResults" class="mt-2 nearby-list"></div>
                    </div>
                </div>
            </div>
    </section>

<!-- Confirmation modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmation de la demande</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="confirmMessage">
                Voulez-vous vraiment envoyer cette demande ?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                <button type="button" class="btn btn-primary" onclick="confirmSubmit()">Oui, confirmer</button>
            </div>
        </div>
    </div>
</div>

<!-- Result modal -->
<div class="modal fade" id="resultModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header" id="resultHeader">
                <h5 class="modal-title" id="resultTitle">Resultat</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="resultMessage">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- Refusal notification modal -->
<div class="modal fade" id="refusalNotificationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-bell me-2"></i>Notification de refus</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <h6 id="refusalNotifTitle" class="fw-bold mb-2"></h6>
                <p id="refusalNotifMessage" class="mb-2"></p>
                <small id="refusalNotifDate" class="text-muted"></small>
            </div>
            <div class="modal-footer">
                <a href="{{ path('imprevu_history') }}" class="btn btn-outline-danger">Voir l'historique</a>
                <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Fermer</button>
            </div>
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="{{ asset('js/alea-google-tools.js') }}"></script>
<script>
let currentEvent = null;
window.currentEvent = null;
let selectedSolution = null;
let selectedEpargneId = null;
const refusalPopup = {{ refusalPopup ? {
    id: refusalPopup.id,
    title: refusalPopup.title,
    message: refusalPopup.message,
    createdAt: refusalPopup.createdAt ? refusalPopup.createdAt|date('d/m/Y H:i') : ''
}|json_encode|raw : 'null' }};
const refusalPopupReadUrl = {{ refusalPopup ? path('app_alea_notification_read', {id: refusalPopup.id})|json_encode|raw : 'null' }};

function markRefusalPopupAsRead() {
    if (!refusalPopupReadUrl) {
        return;
    }

    fetch(refusalPopupReadUrl, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    }).catch(() => {});
}

function showRefusalPopupIfAny() {
    if (!refusalPopup || window.__refusalPopupShown) {
        return;
    }

    const titleEl = document.getElementById('refusalNotifTitle');
    const msgEl = document.getElementById('refusalNotifMessage');
    const dateEl = document.getElementById('refusalNotifDate');
    const modalEl = document.getElementById('refusalNotificationModal');
    if (!titleEl || !msgEl || !dateEl || !modalEl || typeof bootstrap === 'undefined') {
        return;
    }

    window.__refusalPopupShown = true;
    titleEl.textContent = refusalPopup.title || 'Demande refusee';
    msgEl.textContent = refusalPopup.message || '';
    dateEl.textContent = refusalPopup.createdAt ? ('Traitee le : ' + refusalPopup.createdAt) : '';

    modalEl.addEventListener('shown.bs.modal', markRefusalPopupAsRead, { once: true });
    const popupModal = bootstrap.Modal.getOrCreateInstance(modalEl);
    popupModal.show();
}

document.addEventListener('DOMContentLoaded', showRefusalPopupIfAny);
document.addEventListener('turbo:load', showRefusalPopupIfAny);
setTimeout(showRefusalPopupIfAny, 0);

function loadEvent(type, title, amount, desc) {
    const panel = document.getElementById('decisionPanel');
    const icon = document.getElementById('eventIcon');
    const titleElem = document.getElementById('eventTitle');
    const descElem = document.getElementById('eventDesc');
    const amountElem = document.getElementById('eventAmount');
    const negOptions = document.getElementById('negativeOptions');
    const posOptions = document.getElementById('positiveOptions');
    const submitSection = document.getElementById('submitSection');

    currentEvent = { type, title, amount, desc };
    window.currentEvent = currentEvent;
    selectedSolution = null;
    selectedEpargneId = null;

    titleElem.innerText = title;
    descElem.innerText = desc;
    const titleInput = document.getElementById('customTitle');
    const amountInput = document.getElementById('customAmount');
    const typeInput = document.getElementById('customType');
    const descInput = document.getElementById('customDescription');
    if (titleInput) titleInput.value = title || '';
    if (amountInput) amountInput.value = amount || '';
    if (typeInput) typeInput.value = type || '';
    if (descInput) descInput.value = desc || '';

    // Reset UI
    document.querySelectorAll('.solution-btn').forEach(btn => btn.classList.remove('btn-primary', 'btn-secondary'));
    document.querySelectorAll('.solution-btn').forEach(btn => btn.classList.add('btn-light'));
    document.getElementById('epargneSelection').classList.add('d-none');
    document.getElementById('epargneSelectionPos').classList.add('d-none');
    submitSection.classList.add('d-none');

    if (type === 'NEGATIF') {
        panel.className = "bg-white rounded p-5 shadow-sm theme-negative";
        icon.className = "fas fa-tools fa-2x";
        amountElem.innerText = "- " + amount + " DT";
        negOptions.classList.remove('d-none');
        posOptions.classList.add('d-none');
        
        // Update balance colors for negative amount
        updateBalanceColors(amount);
    } else {
        panel.className = "bg-white rounded p-5 shadow-sm theme-positive";
        icon.className = "fas fa-gift fa-2x";
        amountElem.innerText = "+ " + amount + " DT";
        posOptions.classList.remove('d-none');
        negOptions.classList.add('d-none');
    }
}

function updateBalanceColors(amount) {
    document.querySelectorAll('#epargneSelection .epargne-card').forEach(card => {
        const balance = parseFloat(card.dataset.balance);
        const balanceElem = card.querySelector('.epargne-balance');
        if (balance < amount) {
            balanceElem.classList.remove('text-success');
            balanceElem.classList.add('text-danger');
        } else {
            balanceElem.classList.remove('text-danger');
            balanceElem.classList.add('text-success');
        }
    });
}

function addCustomEvent() {
    const title = document.getElementById('customTitle').value;
    const explicitType = document.getElementById('customType').value;
    const amount = document.getElementById('customAmount').value;
    const desc = document.getElementById('customDescription').value || 'Custom case';
    const inferredType = inferTypeFromText((title || '') + ' ' + (desc || ''));
    const type = explicitType || inferredType;
    if(title && amount) {
        loadEvent(type, title, amount, desc);
    } else {
        alert('Veuillez remplir tous les champs.');
    }
}

function inferTypeFromText(text) {
    const t = (text || '').toLowerCase();
    const positive = /\b(plus|positif|gain|prime|bonus|remboursement|vente|bourse|aide|cadeau|don|commission|revenu|salaire)\b/;
    const negative = /\b(moins|negatif|négatif|depense|dépense|facture|panne|fuite|reparation|réparation|maladie|urgence|taxe|credit|crédit)\b/;

    const hasPos = positive.test(t);
    const hasNeg = negative.test(t);
    if (hasPos && !hasNeg) return 'POSITIF';
    if (hasNeg && !hasPos) return 'NEGATIF';
    return 'NEGATIF';
}

function startVoiceCaseInput() {
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    const status = document.getElementById('voiceCaseStatus');
    const btn = document.getElementById('voiceCaseBtn');

    if (!SpeechRecognition) {
        fallbackManualCaseInput('Speech-to-text non supporte par ce navigateur.');
        return;
    }

    const recognition = new SpeechRecognition();
    recognition.lang = 'fr-FR';
    recognition.interimResults = false;
    recognition.maxAlternatives = 1;

    if (status) {
        status.classList.remove('d-none');
        status.textContent = 'Ecoute en cours... Exemple: "panne voiture moins 250"';
    }
    if (btn) btn.disabled = true;

    recognition.onresult = function (event) {
        const transcript = (event.results?.[0]?.[0]?.transcript || '').trim();
        if (!transcript) {
            if (status) status.textContent = 'Aucun texte detecte.';
            return;
        }

        const parsed = parseVoiceCaseText(transcript);
        if (parsed.title) document.getElementById('customTitle').value = parsed.title;
        if (parsed.amount !== null) document.getElementById('customAmount').value = parsed.amount;
        if (parsed.type) document.getElementById('customType').value = parsed.type;

        if (status) {
            status.textContent = 'Texte detecte: "' + transcript + '"';
        }
    };

    recognition.onerror = function (event) {
        const err = event && event.error ? event.error : 'unknown';
        const detailMap = {
            'not-allowed': 'Permission micro refusee',
            'service-not-allowed': 'Service vocal bloque par le navigateur/systeme',
            'no-speech': 'Aucune voix detectee',
            'audio-capture': 'Aucun micro detecte',
            'network': 'Erreur reseau/service vocal',
            'aborted': 'Ecoute annulee',
            'language-not-supported': 'Langue non supportee'
        };
        const detail = detailMap[err] || ('Erreur: ' + err);
        if (status) status.textContent = 'Erreur vocale (' + err + '). Passage en mode manuel...';
        fallbackManualCaseInput('Reconnaissance vocale indisponible.\n' + detail);
    };

    recognition.onend = function () {
        if (btn) btn.disabled = false;
    };

    recognition.start();
}

function fallbackManualCaseInput(reason) {
    if (reason) {
        alert(reason + '\nSaisie manuelle guidee activee.');
    }

    const line = prompt('Entrez: "titre, montant, plus ou moins"\nExemple: Panne voiture, 250, moins');
    if (!line) return;

    const parts = line.split(',');
    const title = (parts[0] || '').trim();
    const amountText = (parts[1] || '').trim().replace(',', '.');
    const sign = (parts[2] || '').trim().toLowerCase();

    const amount = parseFloat(amountText);
    const type = /plus|positif|gain|prime|bonus|remboursement|vente|bourse|aide/.test(sign) ? 'POSITIF' : 'NEGATIF';

    if (title) document.getElementById('customTitle').value = title;
    if (!Number.isNaN(amount)) document.getElementById('customAmount').value = amount;
    document.getElementById('customType').value = type;
}

function parseVoiceCaseText(text) {
    const raw = (text || '').toLowerCase();
    const amountMatch = raw.match(/(\d+(?:[.,]\d+)?)/);
    const amount = amountMatch ? parseFloat(amountMatch[1].replace(',', '.')) : null;

    let type = null;
    if (/\b(moins|negatif|nÃ©gatif|depense|dÃ©pense|expense|panne|fuite|facture|reparation|loyer|urgence)\b/.test(raw)) {
        type = 'NEGATIF';
    } else if (/\b(plus|positif|gain|prime|bonus|remboursement|vente|bourse|aide)\b/.test(raw)) {
        type = 'POSITIF';
    }

    let title = raw
        .replace(/\b(moins|negatif|nÃ©gatif|depense|dÃ©pense|expense|panne|fuite|facture|reparation|plus|positif|gain|prime|bonus|remboursement|vente|bourse|aide)\b/g, ' ')
        .replace(/(\d+(?:[.,]\d+)?)/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    if (title.length > 0) {
        title = title.charAt(0).toUpperCase() + title.slice(1);
    }

    return { title, amount, type };
}

function selectSolution(btn) {
    selectedSolution = btn.dataset.solution;
    
    // Reset all buttons
    document.querySelectorAll('.solution-btn').forEach(b => {
        b.classList.remove('btn-primary');
        b.classList.add('btn-light');
    });
    // Highlight selected
    btn.classList.remove('btn-light');
    btn.classList.add('btn-primary');
    
    // Show/hide epargne selection
    const epargneNeg = document.getElementById('epargneSelection');
    const epargnePos = document.getElementById('epargneSelectionPos');
    
    if (selectedSolution === 'OBJECTIF') {
        if (currentEvent.type === 'NEGATIF') {
            epargneNeg.classList.remove('d-none');
        } else {
            epargnePos.classList.remove('d-none');
        }
    } else {
        epargneNeg.classList.add('d-none');
        epargnePos.classList.add('d-none');
    }
    
    // Show submit section
    document.getElementById('submitSection').classList.remove('d-none');
}

function selectEpargne(card) {
    if (card.classList.contains('disabled')) return;
    
    // Deselect others
    document.querySelectorAll('#epargneSelection .epargne-card').forEach(c => {
        c.classList.remove('selected');
    });
    // Select this one
    card.classList.add('selected');
    selectedEpargneId = card.dataset.id;
}

function selectEpargnePos(card) {
    // Deselect others
    document.querySelectorAll('#epargneSelectionPos .epargne-card').forEach(c => {
        c.classList.remove('selected');
    });
    // Select this one
    card.classList.add('selected');
    selectedEpargneId = card.dataset.id;
}

function submitRequest() {
    if (!currentEvent) {
        alert('Veuillez selectionner un cas.');
        return;
    }
    
    if (!selectedSolution) {
        alert('Veuillez selectionner une option.');
        return;
    }
    
    if ((selectedSolution === 'OBJECTIF') && !selectedEpargneId) {
        alert('Veuillez selectionner un objectif.');
        return;
    }
    
    // Show confirmation modal
    const modal = new bootstrap.Modal(document.getElementById('confirmModal'));
    document.getElementById('confirmMessage').innerHTML = `
        <strong>Titre:</strong> ${currentEvent.title}<br>
        <strong>Type:</strong> ${currentEvent.type === 'NEGATIF' ? 'Depense' : 'Gain'}<br>
        <strong>Montant:</strong> ${currentEvent.amount} DT<br>
        <strong>Solution:</strong> ${getSolutionLabel(selectedSolution)}
        ${selectedEpargneId ? '<br><strong>Objectif:</strong> #' + selectedEpargneId : ''}
    `;
    modal.show();
}

function getSolutionLabel(solution) {
    const labels = {
        'FONDS_SECURITE': 'Emergency Fund',
        'OBJECTIF': selectedEpargneId ? 'Objectif #' + selectedEpargneId : 'Objectif',
        'FAMILLE': 'Famille'
    };
    return labels[solution] || solution;
}

function confirmSubmit() {
    const modalEl = document.getElementById('confirmModal');
    const modal = bootstrap.Modal.getInstance(modalEl);
    modal.hide();
    
    // Prepare form data
    const formData = new FormData();
    const explicitType = document.getElementById('customType')?.value || '';
    formData.append('type', explicitType);
    formData.append('titre', currentEvent.title);
    formData.append('montant', currentEvent.amount);
    formData.append('solution', selectedSolution);
    const descriptionValue = document.getElementById('customDescription')?.value || currentEvent.desc || '';
    formData.append('description', descriptionValue);
    if (selectedEpargneId) {
        formData.append('financial_goal_id', selectedEpargneId);
    }
    const justificatifInput = document.getElementById('customJustificatif');
    if (justificatifInput && justificatifInput.files && justificatifInput.files.length > 0) {
        formData.append('justificatif', justificatifInput.files[0]);
    }
    
    // Send request
    fetch('{{ path('app_alea_submit') }}', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        const resultModal = new bootstrap.Modal(document.getElementById('resultModal'));
        const resultHeader = document.getElementById('resultHeader');
        const resultTitle = document.getElementById('resultTitle');
        
        if (data.success) {
            resultHeader.className = 'modal-header bg-success text-white';
            resultTitle.innerText = 'Succes';
            const priorityHtml = data.priority ? `
                <div class="mt-3">
                    <span class="badge ${data.priority.badgeClass || 'bg-secondary'}">Priorite ${data.priority.level || '-'}</span>
                    <div class="small text-muted mt-1">Score: ${data.priority.score || 0}/100</div>
                </div>
            ` : '';
            document.getElementById('resultMessage').innerHTML = `
                <i class="fas fa-check-circle text-success fa-3x d-block text-center mb-3"></i>
                ${data.message}
                ${priorityHtml}
            `;
        } else {
            resultHeader.className = 'modal-header bg-danger text-white';
            resultTitle.innerText = 'Erreur';
            document.getElementById('resultMessage').innerHTML = `
                <i class="fas fa-times-circle text-danger fa-3x d-block text-center mb-3"></i>
                ${data.message}
            `;
        }
        resultModal.show();
        
        // Reset form on success
        if (data.success) {
            document.getElementById('customTitle').value = '';
            document.getElementById('customAmount').value = '';
            const descriptionInput = document.getElementById('customDescription');
            if (descriptionInput) descriptionInput.value = '';
            const typeInput = document.getElementById('customType');
            if (typeInput) typeInput.value = '';
            const justificatifInput = document.getElementById('customJustificatif');
            if (justificatifInput) justificatifInput.value = '';
            currentEvent = null;
            window.currentEvent = null;
            selectedSolution = null;
            selectedEpargneId = null;
            document.querySelectorAll('.solution-btn').forEach(btn => {
                btn.classList.remove('btn-primary');
                btn.classList.add('btn-light');
            });
            document.getElementById('epargneSelection').classList.add('d-none');
            document.getElementById('epargneSelectionPos').classList.add('d-none');
            document.getElementById('submitSection').classList.add('d-none');
            document.getElementById('eventTitle').innerText = 'Select a case...';
            document.getElementById('eventDesc').innerText = 'Click an event on the left.';
            document.getElementById('eventAmount').innerText = '---';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Une erreur est survenue. Veuillez reessayer.');
    });
}
</script>
{% endblock %}
