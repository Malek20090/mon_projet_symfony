{% extends 'base_pages.html.twig' %}

{% block title %}AI Investment Chat{% endblock %}

{% block body %}
<div class="container" style="margin-top:50px; max-width:600px;">

    <h2>🤖 AI Investment Assistant</h2>

    <form method="post">
        <textarea 
            name="message" 
            class="form-control" 
            rows="3" 
            placeholder="Ex: Invest 500 dollars in Bitcoin"
            required
        ></textarea>

        <button type="submit" class="primary-btn" style="margin-top:10px;">
            Send
        </button>
    </form>

    {% if result is not null %}

    <div style="margin-top:20px; padding:15px; border-radius:10px; background:#f5f5f5;">

        {% if result.success is defined and result.success %}
            <p style="color:green; font-weight:bold;">
                ✅ Investment created successfully!
            </p>
            <p>
                Crypto: {{ result.crypto }} <br>
                Amount: ${{ result.amount }}
            </p>
        {% elseif result.error is defined %}
            <p style="color:red; font-weight:bold;">
                ❌ {{ result.error }}
            </p>
        {% else %}
            <p style="color:red;">
                Unexpected response.
            </p>
        {% endif %}

    </div>

{% endif %}

</div>
{% endblock %}