{% extends 'base_pages.html.twig' %}

{% block title %}Financial Dashboard | Decide${% endblock %}
{% block body_class %}savings-page{% endblock %}

{% block body %}
<section class="container py-4 py-md-5">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold mb-1">Financial Dashboard</h2>
            <p class="text-muted mb-0">Revenue and expense insights from your real data.</p>
            <div class="mt-3">
                <a href="{{ path('app_salary_expense_index') }}" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-2"></i>Go Back
                </a>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12 d-flex gap-2 flex-wrap">
            <a href="{{ path('app_dashboard', { focus: 'all' }) }}" class="btn {{ focus == 'all' ? 'btn-primary' : 'btn-outline-primary' }}">All</a>
            <a href="{{ path('app_dashboard', { focus: 'revenues' }) }}" class="btn {{ focus == 'revenues' ? 'btn-primary' : 'btn-outline-primary' }}">Revenues</a>
            <a href="{{ path('app_dashboard', { focus: 'expenses' }) }}" class="btn {{ focus == 'expenses' ? 'btn-primary' : 'btn-outline-primary' }}">Expenses</a>
        </div>
    </div>

    <div class="row g-4">
        {# Debug: Show raw data #}
        {% if app.debug %}
        <div class="col-12 alert alert-info">
            <h5>Debug Info:</h5>
            <p><strong>Monthly Revenues:</strong> {{ dashboardData.monthly_revenues|json_encode }}</p>
            <p><strong>Expense Categories:</strong> {{ dashboardData.expense_categories|json_encode }}</p>
        </div>
        {% endif %}
        
        {% if focus in ['all', 'revenues'] %}
        <div class="col-12 {{ focus == 'all' ? 'col-lg-7' : 'col-lg-10' }}">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Monthly Revenues</h5>
                </div>
                <div class="card-body">
                    <div style="height: 360px;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {% if focus in ['all', 'expenses'] %}
        <div class="col-12 {{ focus == 'all' ? 'col-lg-5' : 'col-lg-10' }}">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Expense Categories</h5>
                </div>
                <div class="card-body">
                    <div style="height: 360px;">
                        <canvas id="expenseChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Monthly Revenue Chart
    const revenueData = {{ dashboardData.monthly_revenues|json_encode|raw }};
    const revenueCtx = document.getElementById('revenueChart');
    if (revenueCtx && revenueData.length > 0) {
        new Chart(revenueCtx, {
            type: 'bar',
            data: {
                labels: revenueData.map(r => r.month),
                datasets: [{
                    label: 'Monthly Revenues (TND)',
                    data: revenueData.map(r => r.total),
                    backgroundColor: 'rgba(13, 110, 253, 0.70)',
                    borderColor: 'rgba(13, 110, 253, 1)',
                    borderWidth: 1,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    }

    // Expense Category Chart
    const expenseData = {{ dashboardData.expense_categories|json_encode|raw }};
    const expenseCtx = document.getElementById('expenseChart');
    if (expenseCtx && expenseData.length > 0) {
        new Chart(expenseCtx, {
            type: 'pie',
            data: {
                labels: expenseData.map(e => e.category),
                datasets: [{
                    label: 'Expenses by Category',
                    data: expenseData.map(e => e.total),
                    backgroundColor: [
                        '#0d6efd', '#20c997', '#ffc107', '#dc3545', 
                        '#6f42c1', '#fd7e14', '#198754', '#0dcaf0'
                    ],
                    borderColor: '#ffffff',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    }
});
</script>
{% endblock %}
