{% extends 'base_pages.html.twig' %}

{% block title %}Financial Dashboard | Decide${% endblock %}
{% block body_class %}savings-page{% endblock %}

{% block body %}
<section class="container py-4 py-md-5">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold mb-1">Financial Dashboard</h2>
            <p class="text-muted mb-0">Revenue and expense insights from your real data.</p>
            <div class="mt-3">
                <a href="{{ path('app_salary_expense_index') }}" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-2"></i>Go Back
                </a>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12 d-flex gap-2 flex-wrap">
            <a href="{{ path('app_dashboard', { focus: 'all' }) }}" class="btn {{ focus == 'all' ? 'btn-primary' : 'btn-outline-primary' }}">All</a>
            <a href="{{ path('app_dashboard', { focus: 'revenues' }) }}" class="btn {{ focus == 'revenues' ? 'btn-primary' : 'btn-outline-primary' }}">Revenues</a>
            <a href="{{ path('app_dashboard', { focus: 'expenses' }) }}" class="btn {{ focus == 'expenses' ? 'btn-primary' : 'btn-outline-primary' }}">Expenses</a>
        </div>
    </div>

    <div class="row g-4">
        {% if focus in ['all', 'revenues'] %}
        <div class="col-12 {{ focus == 'all' ? 'col-lg-7' : 'col-lg-10' }}">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Monthly Revenues</h5>
                </div>
                <div class="card-body">
                    <div style="height: 360px; position: relative;">
                        <canvas id="monthlyRevenueChartCanvas"></canvas>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}

        {% if focus in ['all', 'expenses'] %}
        <div class="col-12 {{ focus == 'all' ? 'col-lg-5' : 'col-lg-10' }}">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Expense Categories</h5>
                </div>
                <div class="card-body">
                    <div style="height: 360px; position: relative;">
                        <canvas id="expenseCategoryChartCanvas"></canvas>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            const monthlyRows = {{ dashboardData.monthly_revenues|json_encode|raw }};
            const expenseRows = {{ dashboardData.expense_categories|json_encode|raw }};

            const revenueLabels = monthlyRows.map(row => row.month || '');
            const revenueValues = monthlyRows.map(row => Number(row.total || 0));

            const expenseLabels = expenseRows.map(row => row.category || 'Other');
            const expenseValues = expenseRows.map(row => Number(row.total || 0));

            const revenueCanvas = document.getElementById('monthlyRevenueChartCanvas');
            const expenseCanvas = document.getElementById('expenseCategoryChartCanvas');

            if (revenueCanvas) {
                if (revenueLabels.length === 0) {
                    const wrap = revenueCanvas.parentElement;
                    if (wrap) {
                        wrap.innerHTML = '<div class="h-100 d-flex align-items-center justify-content-center text-muted">No revenue data available yet.</div>';
                    }
                } else {
                    new Chart(revenueCanvas, {
                        type: 'bar',
                        data: {
                            labels: revenueLabels,
                            datasets: [{
                                label: 'Monthly Revenues (TND)',
                                data: revenueValues,
                                backgroundColor: 'rgba(13, 110, 253, 0.70)',
                                borderColor: 'rgba(13, 110, 253, 1)',
                                borderWidth: 1,
                                borderRadius: 6
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: true } },
                            scales: { y: { beginAtZero: true } }
                        }
                    });
                }
            }

            if (expenseCanvas) {
                if (expenseLabels.length === 0) {
                    const wrap = expenseCanvas.parentElement;
                    if (wrap) {
                        wrap.innerHTML = '<div class="h-100 d-flex align-items-center justify-content-center text-muted">No expense data available yet.</div>';
                    }
                } else {
                    new Chart(expenseCanvas, {
                        type: 'pie',
                        data: {
                            labels: expenseLabels,
                            datasets: [{
                                label: 'Expenses by Category',
                                data: expenseValues,
                                backgroundColor: ['#0d6efd', '#20c997', '#ffc107', '#dc3545', '#6f42c1', '#fd7e14', '#198754', '#0dcaf0'],
                                borderColor: '#ffffff',
                                borderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { position: 'bottom' } }
                        }
                    });
                }
            }
        })();
    </script>
{% endblock %}
