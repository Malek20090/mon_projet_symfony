<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Salary Statement</title>
    <style>
        @page { margin: 24px; }
        body {
            font-family: DejaVu Sans, Arial, sans-serif;
            color: #0f274a;
            font-size: 12px;
        }
        .header {
            border-bottom: 2px solid #1c67d8;
            padding-bottom: 10px;
            margin-bottom: 16px;
        }
        .brand {
            font-size: 24px;
            font-weight: 700;
            color: #0b4fb8;
            margin: 0;
        }
        .subtitle {
            font-size: 13px;
            color: #3b5f90;
            margin: 4px 0 0;
        }
        .meta {
            margin-top: 12px;
            border: 1px solid #cfe0fb;
            border-radius: 10px;
            padding: 10px 12px;
            background: #f7fbff;
        }
        .meta-row {
            margin: 3px 0;
        }
        .kpi {
            margin-top: 14px;
            width: 100%;
            border-collapse: collapse;
        }
        .kpi td {
            width: 33.33%;
            border: 1px solid #d4e3fa;
            padding: 8px 10px;
            background: #f8fbff;
        }
        .kpi .label {
            display: block;
            color: #4f6e97;
            font-size: 11px;
        }
        .kpi .value {
            display: block;
            margin-top: 2px;
            font-size: 16px;
            font-weight: 700;
            color: #123866;
        }
        table.statement {
            width: 100%;
            border-collapse: collapse;
            margin-top: 14px;
        }
        table.statement th {
            background: #0f5fcf;
            color: #fff;
            text-align: left;
            padding: 7px 8px;
            font-size: 11px;
            border: 1px solid #0d52b1;
        }
        table.statement td {
            padding: 7px 8px;
            border: 1px solid #d8e4f7;
            font-size: 11px;
            vertical-align: top;
        }
        .text-right {
            text-align: right;
        }
        .text-muted {
            color: #5e7597;
        }
        .amount-plus {
            color: #0f6b42;
            font-weight: 700;
        }
        .amount-minus {
            color: #b02a37;
            font-weight: 700;
        }
        .footer {
            margin-top: 14px;
            font-size: 10px;
            color: #5f7391;
            border-top: 1px solid #d7e4f7;
            padding-top: 8px;
            text-align: right;
        }
    </style>
</head>
<body>
<div class="header">
    <h1 class="brand">Decide$ - Bank Statement</h1>
    <p class="subtitle">Professional account extract for salary profile</p>
</div>

<div class="meta">
    <div class="meta-row"><strong>Account Holder:</strong> {{ user.nom ?: user.email }}</div>
    <div class="meta-row"><strong>Email:</strong> {{ user.email }}</div>
    <div class="meta-row"><strong>Generated At:</strong> {{ generatedAt|date('Y-m-d H:i:s') }}</div>
</div>

<table class="kpi">
    <tr>
        <td>
            <span class="label">Opening Balance</span>
            <span class="value">{{ openingBalance|number_format(2, '.', ' ') }} TND</span>
        </td>
        <td>
            <span class="label">Closing Balance</span>
            <span class="value">{{ closingBalance|number_format(2, '.', ' ') }} TND</span>
        </td>
        <td>
            <span class="label">Transactions</span>
            <span class="value">{{ rows|length }}</span>
        </td>
    </tr>
</table>

<table class="statement">
    <thead>
    <tr>
        <th style="width: 8%;">#</th>
        <th style="width: 14%;">Date</th>
        <th style="width: 16%;">Type</th>
        <th style="width: 34%;">Description</th>
        <th style="width: 14%;" class="text-right">Movement</th>
        <th style="width: 14%;" class="text-right">Balance</th>
    </tr>
    </thead>
    <tbody>
    {% for row in rows %}
        <tr>
            <td>{{ loop.index }}</td>
            <td>{{ row.date }}</td>
            <td>{{ row.type }}</td>
            <td class="text-muted">{{ row.description ?: '-' }}</td>
            <td class="text-right {{ row.signed_amount >= 0 ? 'amount-plus' : 'amount-minus' }}">
                {{ row.signed_amount >= 0 ? '+' : '-' }}{{ row.signed_amount|abs|number_format(2, '.', ' ') }}
            </td>
            <td class="text-right">{{ row.running_balance|number_format(2, '.', ' ') }}</td>
        </tr>
    {% else %}
        <tr>
            <td colspan="6" class="text-muted">No transactions available.</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<div class="footer">
    Generated by Decide$ Statement Engine
</div>
</body>
</html>

