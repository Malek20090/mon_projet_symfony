<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Expenses Table</title>
  <style>
    body {
      font-family: DejaVu Sans, sans-serif;
      font-size: 12px;
      color: #1f2937;
    }
    h1 {
      font-size: 20px;
      margin: 0 0 8px;
    }
    .meta {
      margin-bottom: 16px;
      color: #4b5563;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 12px;
    }
    th, td {
      border: 1px solid #d1d5db;
      padding: 8px;
      text-align: left;
      vertical-align: top;
    }
    th {
      background: #f3f4f6;
      font-weight: 700;
    }
    .num {
      text-align: right;
      white-space: nowrap;
    }
    .footer {
      margin-top: 10px;
      font-weight: 700;
      text-align: right;
    }
  </style>
</head>
<body>
  <h1>Expenses Table</h1>
  <div class="meta">
    Generated at: {{ generatedAt|date('Y-m-d H:i') }}<br>
    {% if search %}
      Search filter: "{{ search }}"
    {% else %}
      Search filter: none
    {% endif %}
  </div>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Date</th>
        <th class="num">Amount (TND)</th>
        <th>Category</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {% for expense in expenses %}
        <tr>
          <td>{{ expense.id }}</td>
          <td>{{ expense.expenseDate ? expense.expenseDate|date('Y-m-d') : 'N/A' }}</td>
          <td class="num">{{ expense.amount|number_format(2, '.', ' ') }}</td>
          <td>{{ expense.category }}</td>
          <td>{{ expense.description|default('—') }}</td>
        </tr>
      {% else %}
        <tr>
          <td colspan="5">No expense found.</td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

  <div class="footer">Total expenses: {{ totalExpenses|number_format(2, '.', ' ') }} TND</div>
</body>
</html>
