{% extends 'base_pages.html.twig' %}

{% block title %}Income & Expense | Decide${% endblock %}

{% block body_class %}savings-page{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <link rel="stylesheet" href="{{ asset('css/decides-savings.css') }}?v=1000">
  <style>
    .savings-page .table-wrap { overflow-x: auto; max-width: 100%; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .savings-page .table-history { width: 100%; border-collapse: collapse; background: #fff; font-size: 0.95rem; }
    .savings-page .table-history thead { background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); color: #fff; }
    .savings-page .table-history thead th { padding: 14px 16px; text-align: left; font-weight: 600; white-space: nowrap; border: none; }
    .savings-page .table-history thead th:first-child { border-radius: 0; }
    .savings-page .table-history tbody tr { border-bottom: 1px solid #eee; transition: background 0.15s; }
    .savings-page .table-history tbody tr:hover { background: #f8f9fa; }
    .savings-page .table-history tbody tr:last-child { border-bottom: none; }
    .savings-page .table-history td { padding: 14px 16px; vertical-align: middle; }
    .savings-page .table-history .col-id { width: 50px; text-align: center; color: #6c757d; }
    .savings-page .table-history .col-date { white-space: nowrap; }
    .savings-page .table-history .col-amount { font-weight: 700; color: #0d6efd; white-space: nowrap; }
    .savings-page .table-history .col-actions { white-space: nowrap; }
    .savings-page .table-history .col-actions .btn { padding: 8px 12px; margin: 0 2px; }
    .savings-page .table-history .col-actions form { display: inline; }
    body.night .savings-page .table-wrap { box-shadow: 0 2px 12px rgba(0,0,0,.25); }
    body.night .savings-page .table-history tbody tr { border-bottom-color: rgba(255,255,255,.08); }
    body.night .savings-page .table-history tbody tr:hover { background: rgba(255,255,255,.05); }
    .savings-page .historique-frame { display: flex; flex-direction: column; height: 100%; min-height: 420px; }
    .savings-page .historique-toolbar { flex-shrink: 0; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(0,0,0,.08); }
    body.night .savings-page .historique-toolbar { border-bottom-color: rgba(255,255,255,.1); }
    .savings-page .historique-table-wrap { flex: 1; min-height: 220px; display: flex; flex-direction: column; }
    .savings-page .historique-table-wrap .table-wrap { flex: 1; display: block; }
    .savings-page .advice-highlight {
      margin-top: 12px;
      border-radius: 14px;
      border: 1px solid rgba(13, 110, 253, .22);
      background: linear-gradient(135deg, rgba(13, 110, 253, .08), rgba(0, 191, 229, .12));
      padding: 14px 16px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      box-shadow: 0 6px 18px rgba(13, 110, 253, .12);
    }
    .savings-page .advice-highlight i {
      color: #0d6efd;
      font-size: 1rem;
      margin-top: 2px;
    }
    .savings-page .advice-highlight .advice-month {
      font-weight: 800;
      color: #0f2a52;
      margin-right: 6px;
      white-space: nowrap;
    }
    .savings-page .advice-highlight .advice-text {
      color: #17324f;
      line-height: 1.45;
      font-weight: 600;
    }
    body.night .savings-page .advice-highlight {
      border-color: rgba(56, 189, 248, .35);
      background: linear-gradient(135deg, rgba(14, 38, 82, .8), rgba(8, 26, 58, .8));
      box-shadow: 0 8px 22px rgba(0, 0, 0, .35);
    }
    body.night .savings-page .advice-highlight .advice-month,
    body.night .savings-page .advice-highlight .advice-text {
      color: rgba(236, 252, 255, .92);
    }
    body.night .savings-page .advice-highlight i {
      color: #38bdf8;
    }
    .savings-page .tabs { position: relative; z-index: 3; }
    .savings-page .month-filter-form .form-label { font-weight: 700; color: #5e6f7f; }
    .savings-page .month-filter-form .month-apply-btn {
      min-height: 40px;
      font-weight: 800;
      border-radius: 10px;
      padding-left: 16px;
      padding-right: 16px;
      white-space: nowrap;
    }
    .savings-page .month-filter-form .month-select {
      min-width: 150px;
      font-weight: 700;
      color: #1f3552;
    }
    .savings-page .month-filter-controls {
      display: flex;
      align-items: end;
      gap: 10px;
      flex-wrap: wrap;
    }
    .savings-page .month-filter-controls .field {
      min-width: 170px;
      flex: 1 1 170px;
    }
    .savings-page .month-filter-controls .action {
      min-width: 170px;
      flex: 0 0 170px;
    }
    body.night .savings-page .month-filter-form .month-select {
      color: #e6f6ff;
    }
    @media (max-width: 992px) {
      .savings-page .month-filter-controls .action {
        flex: 1 1 170px;
      }
    }
    .savings-page .recurring-engine-card {
      border-radius: 16px;
      border: 1px solid rgba(13, 110, 253, .18);
      background: linear-gradient(135deg, rgba(13, 110, 253, .06), rgba(0, 191, 229, .1));
      box-shadow: 0 10px 24px rgba(13, 110, 253, .1);
    }
    .savings-page .recurring-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(255px, 1fr));
      gap: 12px;
      margin-top: 10px;
    }
    .savings-page .recurring-item {
      border-radius: 12px;
      background: rgba(255,255,255,.9);
      border: 1px solid rgba(13, 110, 253, .12);
      padding: 12px;
    }
    .savings-page .recurring-item .title {
      font-weight: 800;
      color: #0f2a52;
      margin-bottom: 4px;
      line-height: 1.2;
    }
    .savings-page .recurring-item .meta {
      font-size: .85rem;
      color: #50657b;
      margin-bottom: 8px;
    }
    .savings-page .recurring-item .kind-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 3px 8px;
      font-size: .72rem;
      font-weight: 800;
      margin-right: 6px;
      background: rgba(13,110,253,.1);
      color: #0d6efd;
    }
    .savings-page .recurring-item .confidence {
      font-size: .8rem;
      font-weight: 700;
      color: #0f2a52;
    }
    .savings-page .recurring-rules-list {
      margin-top: 10px;
      font-size: .9rem;
      color: #39506a;
    }
    .savings-page .recurring-rules-list li { margin-bottom: 4px; }
    body.night .savings-page .recurring-engine-card {
      border-color: rgba(56, 189, 248, .3);
      background: linear-gradient(135deg, rgba(14, 38, 82, .8), rgba(8, 26, 58, .8));
      box-shadow: 0 10px 24px rgba(0,0,0,.35);
    }
    body.night .savings-page .recurring-item {
      background: rgba(255,255,255,.05);
      border-color: rgba(56, 189, 248, .28);
    }
    body.night .savings-page .recurring-item .title,
    body.night .savings-page .recurring-item .confidence {
      color: rgba(236, 252, 255, .92);
    }
    body.night .savings-page .recurring-item .meta,
    body.night .savings-page .recurring-rules-list {
      color: rgba(210, 234, 255, .75);
    }
    body.night .savings-page .recurring-item .kind-pill {
      background: rgba(56,189,248,.18);
      color: #9cecff;
    }
  </style>
{% endblock %}

{% block body %}

{% set tabRaw = app.request.query.get('tab', 'revenus') %}
{% set tab = tabRaw in ['revenus', 'expenses'] ? tabRaw : 'revenus' %}

<section class="hero">
  <div class="wrap container text-center">
    <h1>Income & Expense</h1>
    <p>Track your income, manage your expenses, and visualize your financial balance in one place.</p>
  </div>
</section>

<section class="savings-zone">
  <div class="container">

    {% for message in app.flashes('success') %}
      <div class="alert alert-success alert-dismissible fade show" role="alert">{{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endfor %}

    <div class="section-title">
      <div class="kicker">DECIDE$ MODULE</div>
      <h2>Income & Expense Management</h2>
      <p>Manage income and expenses with tri and recherche.</p>
    </div>
    {# KPIs #}
    <div class="kpi-grid stats-row">
      <div class="stat-card">
        <div>
          <h4>Total Income</h4>
          <div class="small">Somme des revenus</div>
          <div class="value">{{ totalIncome|number_format(2, '.', ' ') }} TND</div>
        </div>
        <div class="icon-bubble"><i class="fa-solid fa-wallet"></i></div>
      </div>
      
      <div class="stat-card">
        <div>
          <h4>Total Expenses</h4>
          <div class="small">Total expenses</div>
          <div class="value">{{ totalExpenses|number_format(2, '.', ' ') }} TND</div>
        </div>
        <div class="icon-bubble"><i class="fa-solid fa-credit-card"></i></div>
      </div>
      <div class="stat-card">
        <div>
          <h4>Net Balance</h4>
          <div class="small">Income - Expenses</div>
          <div class="value {{ netBalance >= 0 ? '' : 'text-danger' }}">{{ netBalance|number_format(2, '.', ' ') }} TND</div>
        </div>
        <div class="icon-bubble"><i class="fa-solid fa-balance-scale"></i></div>
      </div>
      <div class="stat-card">
        <div>
          <h4>Last Transaction</h4>
          <div class="small">Latest activity</div>
          <div class="value" style="font-size:1rem;">{{ lastTransactionDate ? lastTransactionDate|date('d/m/Y') : '--/--/----' }}</div>
        </div>
        <div class="icon-bubble"><i class="fa-solid fa-calendar-alt"></i></div>
      </div>
    </div>

    {# Tabs #}
    <div class="tabs">
      <a href="{{ path('app_salary_expense_index', app.request.query.all|merge({'tab': 'revenus'})) }}" class="js-tab tab-pill {{ tab == 'revenus' ? 'active' : '' }}" data-tab="revenus">
        <i class="fa-solid fa-wallet me-2"></i>Revenus
      </a>
      <a href="{{ path('app_salary_expense_index', app.request.query.all|merge({'tab': 'expenses'})) }}" class="js-tab tab-pill {{ tab == 'expenses' ? 'active' : '' }}" data-tab="expenses">
        <i class="fa-solid fa-credit-card me-2"></i>Expenses
      </a>
    </div>

    {# TAB: REVENUS #}
    <div id="tab-revenus" class="tab-panel {{ tab == 'revenus' ? 'show' : '' }}">
      <div class="row g-4">
        <div class="col-lg-5">
          <div class="stat-card p-4">
            <h4 class="mb-3"><i class="fas fa-plus-circle text-primary me-2"></i>Add an income</h4>
            <div class="mb-3">
              <a href="{{ path('app_dashboard', { focus: 'revenues' }) }}" class="btn btn-outline-primary w-100">
                <i class="fa-solid fa-chart-column me-2"></i>Open Revenue Dashboard
              </a>
            </div>
            {{ form_start(formRevenue, { 'attr': { 'class': '' } }) }}
              <div class="mb-3">{{ form_row(formRevenue.amount, { 'attr': { 'class': 'form-control' }, 'label': 'Montant (TND)' }) }}</div>
              <div class="mb-3">{{ form_row(formRevenue.type, { 'attr': { 'class': 'form-select' } }) }}</div>
              <div class="mb-3">{{ form_row(formRevenue.receivedAt, { 'attr': { 'class': 'form-control' }, 'label': 'Date' }) }}</div>
              <div class="mb-3">{{ form_row(formRevenue.description, { 'attr': { 'class': 'form-control' }, 'required': false }) }}</div>
              
              <button type="submit" class="btn-primary2 w-100"><i class="fas fa-plus-circle me-2"></i>Add</button>
            {{ form_end(formRevenue) }}
          </div>
        </div>
        <div class="col-lg-7">
          <div class="stat-card p-4 historique-frame">
            <h4 class="mb-0"><i class="fas fa-history text-primary me-2"></i>Historique des revenus</h4>

            <form method="get" class="historique-toolbar">
              <input type="hidden" name="tab" value="revenus">
              <input type="hidden" name="month" value="{{ selectedMonth }}">
              <div class="row g-2 align-items-end mb-2">
                <div class="col-auto">
                  <label class="form-label small mb-0">Sort (criterion 1)</label>
                  <select name="revenue_sort1" class="form-select form-select-sm">
                    <option value="receivedAt" {{ app.request.query.get('revenue_sort1', 'receivedAt') == 'receivedAt' ? 'selected' : '' }}>Date</option>
                    <option value="amount" {{ app.request.query.get('revenue_sort1') == 'amount' ? 'selected' : '' }}>Montant</option>
                    <option value="type" {{ app.request.query.get('revenue_sort1') == 'type' ? 'selected' : '' }}>Type</option>
                    <option value="createdAt" {{ app.request.query.get('revenue_sort1') == 'createdAt' ? 'selected' : '' }}>Created on</option>
                  </select>
                </div>
                <div class="col-auto">
                  <label class="form-label small mb-0">Sens</label>
                  <select name="revenue_dir1" class="form-select form-select-sm">
                    <option value="DESC" {{ app.request.query.get('revenue_dir1', 'DESC') == 'DESC' ? 'selected' : '' }}>Desc</option>
                    <option value="ASC" {{ app.request.query.get('revenue_dir1') == 'ASC' ? 'selected' : '' }}>Asc</option>
                  </select>
                </div>
                <div class="col-auto">
                  <label class="form-label small mb-0">Criterion 2</label>
                  <select name="revenue_sort2" class="form-select form-select-sm">
                    <option value="amount" {{ app.request.query.get('revenue_sort2', 'amount') == 'amount' ? 'selected' : '' }}>Montant</option>
                    <option value="receivedAt" {{ app.request.query.get('revenue_sort2') == 'receivedAt' ? 'selected' : '' }}>Date</option>
                    <option value="type" {{ app.request.query.get('revenue_sort2') == 'type' ? 'selected' : '' }}>Type</option>
                  </select>
                </div>
                <div class="col-auto">
                  <select name="revenue_dir2" class="form-select form-select-sm">
                    <option value="DESC" {{ app.request.query.get('revenue_dir2', 'DESC') == 'DESC' ? 'selected' : '' }}>Desc</option>
                    <option value="ASC" {{ app.request.query.get('revenue_dir2') == 'ASC' ? 'selected' : '' }}>Asc</option>
                  </select>
                </div>
                <div class="col-auto">
                  <button type="submit" class="btn btn-sm btn-outline-primary"><i class="fas fa-sort me-1"></i>Trier</button>
                </div>
              </div>
              <div class="row g-2 align-items-end">
                <div class="col-auto flex-grow-1">
                  <label class="form-label small mb-0">Recherche</label>
                  <input type="text" name="revenue_search" value="{{ app.request.query.get('revenue_search') }}" class="form-control form-control-sm" placeholder="Type ou description...">
                </div>
                <div class="col-auto">
                  <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search me-1"></i>Rechercher</button>
                </div>
              </div>
            </form>

            <div class="historique-table-wrap">
            <div class="table-wrap">
              <table class="table-history">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Date</th>
                    <th>Montant</th>
                    <th>Type</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {% for revenue in revenues %}
                    <tr>
                      <td class="col-id">{{ revenue.id }}</td>
                      <td class="col-date">{{ revenue.receivedAt ? revenue.receivedAt|date('d/m/Y') : '—' }}</td>
                      <td class="col-amount">{{ revenue.amount|number_format(2, ',', ' ') }} TND</td>
                      <td>{{ revenue.type }}</td>
                      <td class="col-actions">
                        <a href="{{ path('app_salary_expense_revenue_edit', { id: revenue.id }) }}" class="btn btn-sm btn-outline-primary" title="Edit"><i class="fas fa-edit"></i></a>
                        <form method="post" action="{{ path('app_salary_expense_revenue_delete', { id: revenue.id }) }}" class="d-inline" onsubmit="return confirm('Delete this income?');">
                          <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ revenue.id) }}">
                          <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="fas fa-trash"></i></button>
                        </form>
                      </td>
                    </tr>
                  {% else %}
                    <tr><td colspan="5" class="text-center text-muted py-4">No income.</td></tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {# TAB: EXPENSES #}
    <div id="tab-expenses" class="tab-panel {{ tab == 'expenses' ? 'show' : '' }}">
      <div class="stat-card p-4 mb-4">
        <h4 class="mb-3"><i class="fa-solid fa-chart-line text-primary me-2"></i>Advanced Expense Statistics</h4>
        <form method="get" class="row g-2 align-items-end mb-3 month-filter-form">
          <input type="hidden" name="tab" value="expenses">
          <input type="hidden" name="expense_sort1" value="{{ app.request.query.get('expense_sort1', 'expenseDate') }}">
          <input type="hidden" name="expense_dir1" value="{{ app.request.query.get('expense_dir1', 'DESC') }}">
          <input type="hidden" name="expense_sort2" value="{{ app.request.query.get('expense_sort2', 'amount') }}">
          <input type="hidden" name="expense_dir2" value="{{ app.request.query.get('expense_dir2', 'DESC') }}">
          <input type="hidden" name="expense_search" value="{{ app.request.query.get('expense_search', '') }}">
          <input type="hidden" name="revenue_sort1" value="{{ app.request.query.get('revenue_sort1', 'receivedAt') }}">
          <input type="hidden" name="revenue_dir1" value="{{ app.request.query.get('revenue_dir1', 'DESC') }}">
          <input type="hidden" name="revenue_sort2" value="{{ app.request.query.get('revenue_sort2', 'amount') }}">
          <input type="hidden" name="revenue_dir2" value="{{ app.request.query.get('revenue_dir2', 'DESC') }}">
          <input type="hidden" name="revenue_search" value="{{ app.request.query.get('revenue_search', '') }}">
          <div class="col-md-8 col-lg-7">
            <div class="month-filter-controls">
              <div class="field">
                <label class="form-label small mb-0">Choose month</label>
                <select name="month" class="form-select form-select-sm month-select">
                  {% if selectedMonth not in expenseStats.available_months %}
                    <option value="{{ selectedMonth }}" selected>{{ selectedMonth }}</option>
                  {% endif %}
                  {% for monthOption in expenseStats.available_months %}
                    <option value="{{ monthOption }}" {{ selectedMonth == monthOption ? 'selected' : '' }}>{{ monthOption }}</option>
                  {% endfor %}
                </select>
              </div>
              <div class="action">
                <button type="submit" class="btn btn-primary w-100 month-apply-btn">
                  <i class="fa-solid fa-check me-1"></i>Apply Month
                </button>
              </div>
            </div>
          </div>
        </form>
        <div class="row g-3 mb-3">
          <div class="col-md-3">
            <div class="small text-muted">Selected month total ({{ expenseStats.selected_month }})</div>
            <div class="fw-bold">{{ expenseStats.current_month_total|number_format(2, '.', ' ') }} TND</div>
          </div>
          <div class="col-md-3">
            <div class="small text-muted">Previous month total</div>
            <div class="fw-bold">{{ expenseStats.previous_month_total|number_format(2, '.', ' ') }} TND</div>
          </div>
          <div class="col-md-3">
            <div class="small text-muted">Monthly evolution</div>
            <div class="fw-bold {{ expenseStats.evolution_percent > 0 ? 'text-danger' : 'text-success' }}">
              {{ expenseStats.evolution_percent|number_format(2, '.', ' ') }}%
            </div>
          </div>
          <div class="col-md-3">
            <div class="small text-muted">Average monthly spend</div>
            <div class="fw-bold">{{ expenseStats.average_monthly_spend|number_format(2, '.', ' ') }} TND</div>
          </div>
        </div>

        <div>
          <h5 class="mb-2"><i class="fa-solid fa-robot text-primary me-2"></i>AI Monthly Advice</h5>
          {% set selectedAdvice = monthlyAdvice.by_month[expenseStats.selected_month]|default('No AI advice available for the selected month yet.') %}
          <div class="advice-highlight" role="note" aria-live="polite">
            <i class="fa-solid fa-sparkles"></i>
            <div class="advice-text">
              <span class="advice-month">{{ expenseStats.selected_month }}:</span>{{ selectedAdvice }}
            </div>
          </div>
        </div>
      </div>

      <div class="stat-card p-4 mb-4 recurring-engine-card">
        <h4 class="mb-2"><i class="fa-solid fa-repeat text-primary me-2"></i>Recurring Transaction Engine</h4>
        <p class="small mb-2">Detected repeated patterns from your history. Convert one click into automated recurring entries.</p>

        {% if recurringSuggestions is not empty %}
          <div class="recurring-grid">
            {% for suggestion in recurringSuggestions %}
              <div class="recurring-item">
                <div class="title">{{ suggestion.label }}</div>
                <div class="meta">
                  <span class="kind-pill">{{ suggestion.kind }}</span>
                  {{ suggestion.amount|number_format(2, '.', ' ') }} TND • {{ suggestion.frequency }} • next {{ suggestion.next_run_at }}
                </div>
                <div class="meta">Detected from {{ suggestion.occurrences }} similar entries (last: {{ suggestion.last_date }})</div>
                <div class="confidence mb-2">Confidence: {{ (suggestion.confidence * 100)|number_format(0, '.', ' ') }}%</div>
                <form method="post" action="{{ path('app_salary_expense_recurring_accept') }}" class="d-grid">
                  <input type="hidden" name="_token" value="{{ csrf_token('recurring_accept') }}">
                  <input type="hidden" name="kind" value="{{ suggestion.kind }}">
                  <input type="hidden" name="label" value="{{ suggestion.label }}">
                  <input type="hidden" name="amount" value="{{ suggestion.amount }}">
                  <input type="hidden" name="frequency" value="{{ suggestion.frequency }}">
                  <input type="hidden" name="next_run_at" value="{{ suggestion.next_run_at }}">
                  <input type="hidden" name="confidence" value="{{ suggestion.confidence }}">
                  <input type="hidden" name="signature" value="{{ suggestion.signature }}">
                  <input type="hidden" name="description" value="{{ suggestion.description|default('') }}">
                  <input type="hidden" name="revenue_type" value="{{ suggestion.revenue_type|default('FIXE') }}">
                  <input type="hidden" name="expense_category" value="{{ suggestion.expense_category|default('Other') }}">
                  <input type="hidden" name="expense_revenue_id" value="{{ suggestion.expense_revenue_id|default('') }}">
                  <input type="hidden" name="month" value="{{ selectedMonth }}">
                  <button type="submit" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-check me-1"></i>Convert To Recurring Rule
                  </button>
                </form>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="alert alert-light mb-2">
            No strong recurring pattern detected yet. Add more repeated entries to unlock suggestions.
          </div>
        {% endif %}

        {% if recurringRules is not empty %}
          <div class="recurring-rules-list">
            <strong>Active rules:</strong>
            <ul class="mb-0 mt-1">
              {% for rule in recurringRules|slice(0, 6) %}
                <li>{{ rule.kind }} • {{ rule.amount|number_format(2, '.', ' ') }} TND • {{ rule.frequency }} • next {{ rule.nextRunAt ? rule.nextRunAt|date('Y-m-d') : 'n/a' }}</li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>

      <div class="row g-4">
        <div class="col-lg-5">
          <div class="stat-card p-4">
            <h4 class="mb-3"><i class="fas fa-minus-circle text-primary me-2"></i>Add an expense</h4>
            <div class="mb-3">
              <a href="{{ path('app_dashboard', { focus: 'expenses' }) }}" class="btn btn-outline-primary w-100">
                <i class="fa-solid fa-chart-pie me-2"></i>Open Expense Dashboard
              </a>
            </div>
            {{ form_start(formExpense, { 'attr': { 'class': '' } }) }}
              <div class="mb-3">{{ form_row(formExpense.amount, { 'attr': { 'class': 'form-control', 'data-suggest-amount': '1' }, 'label': 'Montant (TND)' }) }}</div>
              <div class="mb-3">{{ form_row(formExpense.category, { 'attr': { 'class': 'form-select', 'data-suggest-category': '1' } }) }}</div>
              <div class="mb-3">{{ form_row(formExpense.expenseDate, { 'attr': { 'class': 'form-control' }, 'label': 'Date' }) }}</div>
              <div class="mb-3">
                {{ form_row(formExpense.description, { 'attr': { 'class': 'form-control', 'data-suggest-description': '1' }, 'required': false }) }}
                <div id="expense-category-suggestion" class="small mt-2 text-muted" style="display:none;"></div>
              </div>
              <div class="mb-3">{{ form_row(formExpense.revenue, { 'attr': { 'class': 'form-select' } }) }}</div>
              <button type="submit" class="btn-primary2 w-100"><i class="fas fa-minus-circle me-2"></i>Add</button>
            {{ form_end(formExpense) }}
          </div>
        </div>
        <div class="col-lg-7">
          <div class="stat-card p-4 historique-frame">
            <h4 class="mb-0"><i class="fas fa-history text-primary me-2"></i>Expense history</h4>

            <form method="get" class="historique-toolbar">
              <input type="hidden" name="tab" value="expenses">
              <input type="hidden" name="month" value="{{ selectedMonth }}">
              <div class="row g-2 align-items-end mb-2">
                <div class="col-auto">
                  <label class="form-label small mb-0">Sort (criterion 1)</label>
                  <select name="expense_sort1" class="form-select form-select-sm">
                    <option value="expenseDate" {{ app.request.query.get('expense_sort1', 'expenseDate') == 'expenseDate' ? 'selected' : '' }}>Date</option>
                    <option value="amount" {{ app.request.query.get('expense_sort1') == 'amount' ? 'selected' : '' }}>Montant</option>
                    <option value="category" {{ app.request.query.get('expense_sort1') == 'category' ? 'selected' : '' }}>Category</option>
                  </select>
                </div>
                <div class="col-auto">
                  <label class="form-label small mb-0">Sens</label>
                  <select name="expense_dir1" class="form-select form-select-sm">
                    <option value="DESC" {{ app.request.query.get('expense_dir1', 'DESC') == 'DESC' ? 'selected' : '' }}>Desc</option>
                    <option value="ASC" {{ app.request.query.get('expense_dir1') == 'ASC' ? 'selected' : '' }}>Asc</option>
                  </select>
                </div>
                <div class="col-auto">
                  <label class="form-label small mb-0">Criterion 2</label>
                  <select name="expense_sort2" class="form-select form-select-sm">
                    <option value="amount" {{ app.request.query.get('expense_sort2', 'amount') == 'amount' ? 'selected' : '' }}>Montant</option>
                    <option value="expenseDate" {{ app.request.query.get('expense_sort2') == 'expenseDate' ? 'selected' : '' }}>Date</option>
                    <option value="category" {{ app.request.query.get('expense_sort2') == 'category' ? 'selected' : '' }}>Category</option>
                  </select>
                </div>
                <div class="col-auto">
                  <select name="expense_dir2" class="form-select form-select-sm">
                    <option value="DESC" {{ app.request.query.get('expense_dir2', 'DESC') == 'DESC' ? 'selected' : '' }}>Desc</option>
                    <option value="ASC" {{ app.request.query.get('expense_dir2') == 'ASC' ? 'selected' : '' }}>Asc</option>
                  </select>
                </div>
                <div class="col-auto">
                  <button type="submit" class="btn btn-sm btn-outline-primary"><i class="fas fa-sort me-1"></i>Trier</button>
                </div>
              </div>
              <div class="row g-2 align-items-end">
                <div class="col-auto flex-grow-1">
                  <label class="form-label small mb-0">Recherche</label>
                  <input type="text" name="expense_search" value="{{ app.request.query.get('expense_search') }}" class="form-control form-control-sm" placeholder="Category ou description...">
                </div>
                <div class="col-auto">
                  <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search me-1"></i>Rechercher</button>
                </div>
              </div>
            </form>

            <div class="historique-table-wrap">
            <div class="table-wrap">
              <table class="table-history">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Date</th>
                    <th>Montant</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {% for expense in expenses %}
                    <tr>
                      <td class="col-id">{{ expense.id }}</td>
                      <td class="col-date">{{ expense.expenseDate ? expense.expenseDate|date('d/m/Y') : '—' }}</td>
                      <td class="col-amount">{{ expense.amount|number_format(2, ',', ' ') }} TND</td>
                      <td>{{ expense.category }}</td>
                      <td>{{ expense.description|default('—') }}</td>
                      <td class="col-actions">
                        <a href="{{ path('app_salary_expense_expense_edit', { id: expense.id }) }}" class="btn btn-sm btn-outline-primary" title="Edit"><i class="fas fa-edit"></i></a>
                        <form method="post" action="{{ path('app_salary_expense_expense_delete', { id: expense.id }) }}" class="d-inline" onsubmit="return confirm('Delete this expense?');">
                          <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ expense.id) }}">
                          <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"><i class="fas fa-trash"></i></button>
                        </form>
                      </td>
                    </tr>
                  {% else %}
                    <tr><td colspan="6" class="text-center text-muted py-4">No expense.</td></tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const tabBtns = document.querySelectorAll('.js-tab');
  const panels = { revenus: document.getElementById('tab-revenus'), expenses: document.getElementById('tab-expenses') };
  if (tabBtns.length && (panels.revenus || panels.expenses)) {
    function showTab(name) {
      tabBtns.forEach(b => b.classList.toggle('active', b.dataset.tab === name));
      Object.keys(panels).forEach(k => { if (panels[k]) panels[k].classList.toggle('show', k === name); });
      try { const url = new URL(window.location.href); url.searchParams.set('tab', name); window.history.replaceState({}, '', url.toString()); } catch (e) {}
    }
    tabBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const name = btn.dataset.tab;
        if (!name || !panels[name]) return;
        e.preventDefault();
        showTab(name);
      });
    });
    const urlTab = new URL(window.location.href).searchParams.get('tab');
    if (urlTab && panels[urlTab]) showTab(urlTab);
    else { const activeBtn = document.querySelector('.js-tab.active'); showTab(activeBtn ? activeBtn.dataset.tab : 'revenus'); }
  }

  const descEl = document.querySelector('[data-suggest-description="1"]');
  const amountEl = document.querySelector('[data-suggest-amount="1"]');
  const categoryEl = document.querySelector('[data-suggest-category="1"]');
  const hintEl = document.getElementById('expense-category-suggestion');

  if (descEl && amountEl && categoryEl && hintEl) {
    let timer = null;

    const renderSuggestion = (payload) => {
      if (!payload || !payload.category) {
        hintEl.style.display = 'none';
        hintEl.textContent = '';
        return;
      }

      const confidencePct = Math.round((Number(payload.confidence || 0) * 100));
      const alt = Array.isArray(payload.alternatives) && payload.alternatives.length
        ? ` | Alternatives: ${payload.alternatives.map(a => `${a.category} (${Math.round((a.score || 0) * 100)}%)`).join(', ')}`
        : '';

      hintEl.innerHTML = `Suggested category: <strong>${payload.category}</strong> (confidence: <strong>${confidencePct}%</strong>) <button type="button" class="btn btn-sm btn-outline-primary ms-2" id="apply-category-suggestion">Apply</button>${alt}`;
      hintEl.style.display = '';

      const applyBtn = document.getElementById('apply-category-suggestion');
      if (applyBtn) {
        applyBtn.addEventListener('click', function () {
          categoryEl.value = payload.category;
          categoryEl.dispatchEvent(new Event('change', { bubbles: true }));
        }, { once: true });
      }
    };

    const requestSuggestion = async () => {
      const description = (descEl.value || '').trim();
      const amount = (amountEl.value || '').trim();
      if (!description && !amount) {
        renderSuggestion(null);
        return;
      }
      try {
        const url = new URL('{{ path('app_salary_expense_expense_suggest_category') }}', window.location.origin);
        if (description) url.searchParams.set('description', description);
        if (amount) url.searchParams.set('amount', amount);
        const res = await fetch(url.toString(), { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        if (!res.ok) {
          hintEl.style.display = '';
          hintEl.textContent = 'Category suggestion unavailable right now.';
          return;
        }
        const payload = await res.json();
        renderSuggestion(payload);
      } catch (e) {
        hintEl.style.display = '';
        hintEl.textContent = 'Category suggestion unavailable right now.';
      }
    };

    const schedule = () => {
      clearTimeout(timer);
      timer = setTimeout(requestSuggestion, 350);
    };

    descEl.addEventListener('input', schedule);
    amountEl.addEventListener('input', schedule);
    descEl.addEventListener('change', schedule);
    amountEl.addEventListener('change', schedule);
    descEl.addEventListener('blur', schedule);
    amountEl.addEventListener('blur', schedule);
    schedule();
  }
});
</script>
{% endblock %}




