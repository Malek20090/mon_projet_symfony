<div id="smartBotRoot" class="smartbot-root" aria-live="polite">
  <button id="smartBotToggle" class="smartbot-toggle" type="button">
    <span class="smartbot-dot"></span>
    <span>AI Coach</span>
  </button>

  <div id="smartBotPanel" class="smartbot-panel" style="display:none;">
    <div class="smartbot-head">
      <div>
        <div class="smartbot-title">Smart Assistant Chatbot</div>
        <div class="smartbot-state">DB-aware + Any-topic Q&A</div>
      </div>
      <button id="smartBotClose" class="smartbot-close" type="button">x</button>
    </div>
    <div class="smartbot-sub">Ask anything: your database insights, coding, writing, study, or finance questions.</div>

    <div id="smartBotSuggestions" class="smartbot-suggestions"></div>
    <div id="smartBotMessages" class="smartbot-messages"></div>

    <form id="smartBotForm" class="smartbot-form">
      <input id="smartBotInput" class="smartbot-input" type="text" placeholder="Ask your question..." maxlength="800">
      <button id="smartBotMic" class="smartbot-mic" type="button" title="Voice input" aria-label="Voice input">🎤</button>
      <button class="smartbot-send" type="submit">Send</button>
    </form>
    <div id="smartBotVoiceState" class="smartbot-voice-state" aria-live="polite"></div>
  </div>
</div>

<style>
  .smartbot-root {
    position: fixed;
    right: 22px;
    bottom: 20px;
    z-index: 99990;
  }
  .smartbot-toggle {
    border: 0;
    border-radius: 999px;
    padding: 12px 16px 12px 12px;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-weight: 800;
    color: #fff;
    letter-spacing: .2px;
    background: linear-gradient(135deg, #0ea5e9, #0891b2 46%, #0f766e 100%);
    box-shadow: 0 14px 34px rgba(14, 165, 233, .36);
    transition: transform .16s ease, box-shadow .16s ease;
  }
  .smartbot-toggle:hover {
    transform: translateY(-1px);
    box-shadow: 0 18px 36px rgba(14, 165, 233, .44);
  }
  .smartbot-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #d9ffed;
    box-shadow: 0 0 0 0 rgba(217,255,237,.8);
    animation: smartbotPulse 1.8s infinite;
  }
  @keyframes smartbotPulse {
    0% { box-shadow: 0 0 0 0 rgba(217,255,237,.85); }
    70% { box-shadow: 0 0 0 10px rgba(217,255,237,0); }
    100% { box-shadow: 0 0 0 0 rgba(217,255,237,0); }
  }
  .smartbot-panel {
    width: min(420px, 92vw);
    height: min(72vh, 640px);
    margin-top: 10px;
    border: 1px solid #bdd8ee;
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255,255,255,.96) 0%, rgba(246,251,255,.96) 100%);
    backdrop-filter: blur(10px);
    display: flex;
    flex-direction: column;
    box-shadow: 0 22px 50px rgba(16, 38, 64, 0.28);
  }
  .smartbot-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px 2px;
  }
  .smartbot-title {
    font-size: 1rem;
    font-weight: 800;
    color: #12324d;
  }
  .smartbot-state {
    font-size: .76rem;
    color: #4b789d;
    margin-top: 2px;
    font-weight: 600;
  }
  .smartbot-close {
    border: 0;
    background: #f0f7fe;
    border: 1px solid #d5e6f4;
    width: 30px;
    height: 30px;
    border-radius: 10px;
    font-size: .9rem;
    font-weight: 800;
    color: #42617f;
  }
  .smartbot-sub {
    padding: 0 14px 10px;
    color: #637e96;
    font-size: .88rem;
  }
  .smartbot-suggestions {
    padding: 0 12px 10px;
    display: flex;
    gap: 8px;
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: #9ab9d3 transparent;
  }
  .smartbot-suggestions::-webkit-scrollbar {
    height: 6px;
  }
  .smartbot-suggestions::-webkit-scrollbar-thumb {
    background: #9ab9d3;
    border-radius: 999px;
  }
  .smartbot-chip {
    border: 1px solid #d5e6f5;
    background: #f7fbff;
    border-radius: 999px;
    padding: 6px 10px;
    font-size: .8rem;
    color: #1e3e5a;
    cursor: pointer;
    white-space: nowrap;
    flex: 0 0 auto;
    max-width: 240px;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.2;
  }
  .smartbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
  }
  .smartbot-msg {
    max-width: 88%;
    border-radius: 13px;
    padding: 9px 11px;
    font-size: .92rem;
    line-height: 1.4;
    white-space: pre-wrap;
  }
  .smartbot-msg.user {
    align-self: flex-end;
    background: #0ea5e9;
    color: #fff;
  }
  .smartbot-msg.bot {
    align-self: flex-start;
    background: #e9f4ff;
    color: #173956;
    border: 1px solid #d2e8fa;
  }
  .smartbot-meta {
    font-size: .75rem;
    color: #5d7e99;
    margin-top: 4px;
  }
  .smartbot-form {
    border-top: 1px solid #e1edf7;
    padding: 10px;
    display: flex;
    gap: 8px;
  }
  .smartbot-input {
    flex: 1;
    border: 1px solid #cfe0f0;
    border-radius: 10px;
    padding: 9px 10px;
    font-size: .9rem;
  }
  .smartbot-send {
    border: 0;
    border-radius: 10px;
    padding: 9px 12px;
    font-weight: 700;
    color: #fff;
    background: #0ea5e9;
  }
  .smartbot-mic {
    border: 1px solid #cfe0f0;
    border-radius: 10px;
    padding: 9px 10px;
    font-weight: 700;
    color: #173956;
    background: #f3f9ff;
    min-width: 42px;
  }
  .smartbot-mic.listening {
    color: #fff;
    background: #ef4444;
    border-color: #ef4444;
  }
  .smartbot-voice-state {
    min-height: 18px;
    padding: 0 12px 8px;
    color: #5d7e99;
    font-size: .76rem;
  }
  @media (max-width: 820px) {
    .smartbot-root {
      right: 10px;
      left: 10px;
      bottom: 10px;
    }
    .smartbot-toggle {
      width: 100%;
      justify-content: center;
    }
    .smartbot-panel {
      width: 100%;
      height: min(66vh, 560px);
    }
  }
</style>

<script>
(() => {
  const root = document.getElementById('smartBotRoot');
  const toggle = document.getElementById('smartBotToggle');
  const panel = document.getElementById('smartBotPanel');
  const close = document.getElementById('smartBotClose');
  const list = document.getElementById('smartBotMessages');
  const suggestions = document.getElementById('smartBotSuggestions');
  const form = document.getElementById('smartBotForm');
  const input = document.getElementById('smartBotInput');
  const micBtn = document.getElementById('smartBotMic');
  const voiceState = document.getElementById('smartBotVoiceState');
  if (!root || !toggle || !panel || !close || !list || !suggestions || !form || !input || !micBtn || !voiceState) return;

  const history = [];
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  let recognition = null;
  let isListening = false;

  function setVoiceState(text) {
    voiceState.textContent = text || '';
  }

  function pushMsg(role, text, meta = '') {
    const bubble = document.createElement('div');
    bubble.className = `smartbot-msg ${role === 'user' ? 'user' : 'bot'}`;
    bubble.textContent = text || '';
    if (meta && role !== 'user') {
      const m = document.createElement('div');
      m.className = 'smartbot-meta';
      m.textContent = meta;
      bubble.appendChild(m);
    }
    list.appendChild(bubble);
    list.scrollTop = list.scrollHeight;
  }

  async function loadSuggestions() {
    try {
      const res = await fetch(`{{ path('app_savings_assistant_suggestions') }}`, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      });
      const data = await res.json();
      if (!res.ok || !data || data.ok === false) return;
      const items = Array.isArray(data.suggestions) ? data.suggestions : [];
      suggestions.innerHTML = '';
      items.slice(0, 6).forEach((q) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.className = 'smartbot-chip';
        b.title = q;
        b.textContent = q;
        b.addEventListener('click', () => {
          input.value = q;
          input.focus();
        });
        suggestions.appendChild(b);
      });
    } catch (e) {}
  }

  async function ask(message) {
    pushMsg('user', message);
    pushMsg('bot', 'Thinking...');

    history.push({ role: 'user', content: message });
    try {
      const res = await fetch(`{{ path('app_savings_assistant_chat') }}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest',
        },
        body: JSON.stringify({ message, history }),
      });
      const data = await res.json();
      list.removeChild(list.lastElementChild);

      if (!res.ok || !data || data.ok === false) {
        const err = data && (data.reply || data.message)
          ? String(data.reply || data.message)
          : 'Could not process your question.';
        pushMsg('bot', err);
        return;
      }

      const reply = String(data.reply || '');
      const meta = data.source === 'openai'
        ? `Source: OpenAI${data.model ? ` (${data.model})` : ''}`
        : (data.source === 'unavailable'
            ? 'Source: unavailable (configure OPENAI_API_KEY)'
            : 'Source: local fallback');
      pushMsg('bot', reply, meta);
      history.push({ role: 'assistant', content: reply });
    } catch (e) {
      list.removeChild(list.lastElementChild);
      pushMsg('bot', 'Network error, please try again.');
    }
  }

  function initVoiceInput() {
    if (!SpeechRecognition) {
      micBtn.disabled = true;
      setVoiceState('Voice input is not supported in this browser.');
      return;
    }

    recognition = new SpeechRecognition();
    recognition.lang = 'en-US';
    recognition.interimResults = true;
    recognition.continuous = false;

    recognition.onstart = () => {
      isListening = true;
      micBtn.classList.add('listening');
      setVoiceState('Listening...');
    };

    recognition.onresult = (event) => {
      let transcript = '';
      for (let i = event.resultIndex; i < event.results.length; i++) {
        transcript += event.results[i][0].transcript || '';
      }
      transcript = transcript.trim();
      if (transcript !== '') {
        input.value = transcript;
      }
    };

    recognition.onerror = (event) => {
      const code = event && event.error ? event.error : 'unknown';
      setVoiceState(code === 'not-allowed'
        ? 'Microphone access denied.'
        : 'Voice recognition error. Try again.');
    };

    recognition.onend = () => {
      isListening = false;
      micBtn.classList.remove('listening');
      if (input.value.trim() !== '') {
        setVoiceState('Voice captured.');
      } else {
        setVoiceState('Voice input stopped.');
      }
    };

    micBtn.addEventListener('click', () => {
      if (!recognition) return;
      if (isListening) {
        recognition.stop();
        return;
      }
      try {
        recognition.start();
      } catch (e) {
        setVoiceState('Unable to start voice input.');
      }
    });
  }

  toggle.addEventListener('click', () => {
    const opening = panel.style.display === 'none';
    panel.style.display = opening ? 'flex' : 'none';
    if (opening && list.children.length === 0) {
      pushMsg('bot', 'Hi. Ask me any question. I can use your savings/goals data when needed, and handle general topics too.');
      loadSuggestions();
    }
  });
  close.addEventListener('click', () => panel.style.display = 'none');

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const message = input.value.trim();
    if (!message) return;
    input.value = '';
    ask(message);
  });

  initVoiceInput();
})();
</script>
