<div class="modal" id="simModal" aria-hidden="true">
  <div class="modal-card sim-modal-card">
    <div class="modal-head">
      <div class="modal-title">What-if AI Planner</div>
      <button class="close-x" type="button" data-close-modal>&times;</button>
    </div>

    <div class="sub sim-sub">Run one scenario on one goal and get consequence-focused guidance.</div>

    <div class="mt-16 sim-grid-2">
      <div>
        <label class="form-label">Goal</label>
        <select id="simGoal" class="form-control">
          {% set simGoals = goals is iterable ? goals : [] %}
          {% if simGoals|length == 0 %}
            <option value="0">No goals available</option>
          {% else %}
            {% for g in simGoals %}
              {% set gid = attribute(g,'id')|default(0) %}
              {% set gname = attribute(g,'nom')|default('Goal') %}
              <option value="{{ gid }}">{{ gname }}</option>
            {% endfor %}
          {% endif %}
        </select>
      </div>
      <div>
        <label class="form-label">Scenario Type</label>
        <select id="simScenario" class="form-control">
          <option value="deposit_adjustment" selected>Deposit Adjustment</option>
          <option value="deadline_adjustment">Deadline Adjustment</option>
          <option value="target_adjustment">Target Adjustment</option>
        </select>
      </div>
    </div>

    <div class="mt-16 sim-grid-2">
      <div>
        <label class="form-label">Monthly deposit (TND)</label>
        <input class="range" id="simMonthly" type="range" min="0" max="5000" step="50" value="200">
        <div class="tiny-note" style="margin-top:6px;">Value: <b><span id="simMonthlyVal">200</span> TND</b></div>
      </div>
      <div>
        <label class="form-label">One-time deposit (TND)</label>
        <input class="form-control" id="simOneTime" type="number" min="0" step="10" value="0">
      </div>
    </div>

    <div class="mt-16 sim-grid-2" id="simScenarioInputs">
      <div id="simDeadlineWrap" style="display:none;">
        <label class="form-label">Deadline adjustment (months)</label>
        <input class="form-control" id="simDeadlineMonths" type="number" min="-24" max="24" step="1" value="0">
      </div>
      <div id="simTargetWrap" style="display:none;">
        <label class="form-label">Target adjustment (TND)</label>
        <input class="form-control" id="simTargetAmount" type="number" step="10" value="0">
      </div>
    </div>

    <div class="mt-16">
      <button class="primary-btn" type="button" id="simRun">Run simulation</button>
    </div>

    <div class="sim-box mt-16 sim-kpi-grid">
      <div class="sim-kpi sim-kpi-card">
        <div class="lbl">Finish date</div>
        <div class="val"><span id="simFinishDate">-</span></div>
      </div>
      <div class="sim-kpi sim-kpi-card">
        <div class="lbl">Risk level</div>
        <div class="val"><span id="simRisk">-</span></div>
      </div>
      <div class="sim-kpi sim-kpi-card">
        <div class="lbl">Feasibility score</div>
        <div class="val"><span id="simFeasibility">-</span></div>
      </div>
      <div class="sim-kpi sim-kpi-card">
        <div class="lbl">Deadline confidence</div>
        <div class="val"><span id="simConfidence">-</span></div>
      </div>
    </div>

    <div class="sim-box mt-16 sim-insights" id="simImpactSummary">
      Impact Summary will appear after running simulation.
    </div>

    <div class="sim-box mt-16 sim-insights">
      <div class="sim-h" style="margin-top:0;">Executive Insight</div>
      <div id="simExecutiveInsight">-</div>
      <div class="sim-h">Why</div>
      <div id="simWhy">-</div>
      <div class="sim-h">Best Action</div>
      <div id="simBestAction">-</div>
      <div class="sim-h">Alternatives</div>
      <ul id="simAlternatives" class="sim-ul"><li class="sim-li">-</li></ul>
      <div class="sim-h">Next 7 days</div>
      <div id="simNext7">-</div>
    </div>

    <details class="sim-box mt-16">
      <summary style="cursor:pointer; font-weight:700;">Show details</summary>
      <div id="simDetails" style="margin-top:10px; font-size:13px; color:#38506a;">No details yet.</div>
    </details>

    <div class="mt-16" style="display:flex; gap:10px; flex-wrap:wrap;">
      <button class="chip" type="button" data-close-modal style="border:1px solid #d8e4ef;">Close</button>
    </div>
  </div>
</div>

<style>
  #simModal .sim-modal-card {
    width: min(900px, calc(100vw - 72px));
    max-height: calc(100vh - 56px);
    overflow-y: auto;
    margin: 28px auto;
    border: 1px solid #d8e5f1;
    border-radius: 18px;
    box-shadow: 0 20px 45px rgba(11, 30, 53, 0.12);
    background: linear-gradient(180deg, #fbfdff 0%, #f5f9ff 100%);
  }
  #simModal { align-items: flex-start; overflow-y: auto; }
  #simModal .sim-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  #simModal .sim-kpi-grid { display:grid; grid-template-columns:repeat(4, 1fr); gap:12px; }
  #simModal .sim-kpi-card { border:1px solid #d8e5f1; border-radius:12px; padding:12px; background:#fff; }
  #simModal .sim-kpi-card .lbl { font-size:.9rem; color:#607991; margin-bottom:5px; font-weight:600; }
  #simModal .sim-kpi-card .val { font-size:1.7rem; line-height:1.1; font-weight:800; color:#142c44; }
  #simModal .sim-insights { border:1px dashed #b8d3ec; border-radius:12px; padding:12px; background:rgba(237,246,255,.55); color:#2e4a63; line-height:1.5; }
  #simModal .sim-h { font-weight:800; color:#153a5d; margin-top:10px; margin-bottom:6px; }
  #simModal .sim-ul { margin: 0; padding-left: 20px; }
  @media (max-width: 900px) {
    #simModal .sim-grid-2, #simModal .sim-kpi-grid { grid-template-columns:1fr; }
    #simModal .sim-modal-card { width:min(96vw, 96vw); margin:10px auto; }
  }
</style>

<script>
(() => {
  const modal = document.getElementById('simModal');
  const openBtn = document.getElementById('openSimulation');
  const closeBtns = modal ? modal.querySelectorAll('[data-close-modal]') : [];
  const goal = document.getElementById('simGoal');
  const scenario = document.getElementById('simScenario');
  const monthly = document.getElementById('simMonthly');
  const monthlyVal = document.getElementById('simMonthlyVal');
  const oneTime = document.getElementById('simOneTime');
  const deadlineWrap = document.getElementById('simDeadlineWrap');
  const targetWrap = document.getElementById('simTargetWrap');
  const deadlineMonths = document.getElementById('simDeadlineMonths');
  const targetAmount = document.getElementById('simTargetAmount');
  const runBtn = document.getElementById('simRun');

  const finish = document.getElementById('simFinishDate');
  const risk = document.getElementById('simRisk');
  const feas = document.getElementById('simFeasibility');
  const conf = document.getElementById('simConfidence');
  const impact = document.getElementById('simImpactSummary');
  const execInsight = document.getElementById('simExecutiveInsight');
  const why = document.getElementById('simWhy');
  const best = document.getElementById('simBestAction');
  const alts = document.getElementById('simAlternatives');
  const next7 = document.getElementById('simNext7');
  const details = document.getElementById('simDetails');

  if (!modal || !openBtn || !goal || !scenario || !monthly || !monthlyVal || !oneTime || !deadlineWrap || !targetWrap || !deadlineMonths || !targetAmount || !runBtn || !finish || !risk || !feas || !conf || !impact || !execInsight || !why || !best || !alts || !next7 || !details) return;

  const baselineMonthlyDeposit = Number(monthly.value || 0);

  function openModal(){ modal.style.display='flex'; modal.classList.add('show'); modal.setAttribute('aria-hidden','false'); }
  function closeModal(){ modal.style.display='none'; modal.classList.remove('show'); modal.setAttribute('aria-hidden','true'); }

  function syncMonthly(){ monthlyVal.textContent = String(monthly.value || '0'); }

  function syncScenarioInputs(){
    const t = String(scenario.value || 'deposit_adjustment');
    deadlineWrap.style.display = (t === 'deadline_adjustment') ? '' : 'none';
    targetWrap.style.display = (t === 'target_adjustment') ? '' : 'none';
  }

  function asDeltaMonthsText(delta){
    if (delta === null || delta === undefined) return 'n/a';
    const n = Number(delta);
    if (!Number.isFinite(n) || n === 0) return 'no change';
    return n > 0 ? `${Math.abs(n)} month(s) earlier` : `${Math.abs(n)} month(s) later`;
  }

  function asRequiredAdjustmentText(value){
    const n = Number(value || 0);
    if (!Number.isFinite(n) || n === 0) return 'No monthly adjustment needed.';
    if (n < 0) return `You can reduce by ${Math.abs(n).toFixed(2)} TND/month and still stay safe.`;
    return `Increase by ${n.toFixed(2)} TND/month to stay safe.`;
  }

  function render(res){
    const m = res.metrics || {};
    const a = res.advice || {};
    const imp = res.impact_summary || {};

    finish.textContent = String(m.projected_finish_date || '-');
    risk.textContent = String(m.risk_level || '-');
    feas.textContent = `${Number(m.feasibility_score || 0).toFixed(1)} / 100`;
    conf.textContent = `${Number(m.deadline_confidence || 0).toFixed(1)}%`;

    impact.innerHTML = `
      <b>Impact Summary</b><br>
      Finish date change: <b>${asDeltaMonthsText(imp.delta_months)}</b><br>
      Required adjustment (safe): <b>${asRequiredAdjustmentText(imp.required_adjustment_tnd)}</b><br>
      Risk level: <b>${String(m.risk_level || '-')}</b><br>
      Feasibility: <b>${Number(m.feasibility_score || 0).toFixed(1)}/100</b> · Deadline confidence: <b>${Number(m.deadline_confidence || 0).toFixed(1)}%</b>
    `;

    execInsight.textContent = String(a.executive_insight || '-');
    why.textContent = String(a.why || '-');

    const bestTitle = a.best_action && a.best_action.title ? String(a.best_action.title) : '';
    const bestDetails = a.best_action && a.best_action.details ? String(a.best_action.details) : '';
    best.innerHTML = bestTitle
      ? `<b>${bestTitle}:</b> ${bestDetails || '-'}`
      : (bestDetails || '-');

    const altList = Array.isArray(a.alternatives) ? a.alternatives : [];
    alts.innerHTML = altList.length
      ? altList.map((x) => {
          const t = x && x.title ? String(x.title) : 'Alternative';
          const d = x && x.details ? String(x.details) : '-';
          return `<li class="sim-li"><b>${t}:</b> ${d}</li>`;
        }).join('')
      : '<li class="sim-li">No alternatives.</li>';

    next7.textContent = String(a.next_7_days || '-');

    const detailRows = [
      ['Goal', m.goal_name || '-'],
      ['Current saved', `${Number(m.current_saved || 0).toFixed(2)} TND`],
      ['Target amount', `${Number(m.target_amount || 0).toFixed(2)} TND`],
      ['Deadline', m.deadline_date || '-'],
      ['Projected finish', m.projected_finish_date || '-'],
      ['Months to finish', m.months_to_finish === null || m.months_to_finish === undefined ? 'n/a' : String(m.months_to_finish)],
      ['Remaining after now', `${Number(m.remaining_after_now || 0).toFixed(2)} TND`],
      ['Required monthly to hit deadline', `${Number(m.required_monthly_to_hit_deadline || 0).toFixed(2)} TND`],
      ['Deadline gap', `${Number(m.deadline_gap_months || 0)} month(s)`],
      ['Risk level', String(m.risk_level || '-')],
      ['Feasibility score', `${Number(m.feasibility_score || 0).toFixed(1)} / 100`],
      ['Deadline confidence', `${Number(m.deadline_confidence || 0).toFixed(1)}%`],
      ['Required adjustment', `${Number(m.required_adjustment_tnd || 0).toFixed(2)} TND/month`],
      ['Finish date delta', asDeltaMonthsText(imp.delta_months)],
    ];
    details.innerHTML = detailRows.map(([k, v]) => `<div><b>${k}:</b> ${String(v)}</div>`).join('');
  }

  async function runSimulation(){
    runBtn.disabled = true;
    runBtn.textContent = 'Calculating...';
    try {
      const body = {
        selected_goal_id: Number(goal.value || 0),
        scenario_type: String(scenario.value || 'deposit_adjustment'),
        monthly_deposit: Number(monthly.value || 0),
        one_time_deposit: Number(oneTime.value || 0),
        deadline_adjustment_months: Number(deadlineMonths.value || 0),
        target_adjustment_amount: Number(targetAmount.value || 0),
        baseline_monthly_deposit: baselineMonthlyDeposit,
      };

      const res = await fetch(`{{ path('app_savings_what_if') }}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest',
        },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (!res.ok || !data || data.ok === false) {
        throw new Error((data && (data.message || data.error)) ? String(data.message || data.error) : 'Simulation failed');
      }
      render(data);
    } catch (e) {
      impact.textContent = e && e.message ? e.message : 'Could not run simulation.';
    } finally {
      runBtn.disabled = false;
      runBtn.textContent = 'Run simulation';
    }
  }

  openBtn.addEventListener('click', openModal);
  closeBtns.forEach((b) => b.addEventListener('click', closeModal));
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  monthly.addEventListener('input', syncMonthly);
  scenario.addEventListener('change', syncScenarioInputs);
  runBtn.addEventListener('click', runSimulation);

  syncMonthly();
  syncScenarioInputs();
})();
</script>
