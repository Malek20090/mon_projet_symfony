{% extends 'base_pages.html.twig' %}
{% block title %}My Student Profile | Decide${% endblock %}
{% block body_class %}student-profile-page{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.student-profile-page{min-height:100vh;background:radial-gradient(circle at 8% 10%,rgba(30,104,255,.30),transparent 38%),radial-gradient(circle at 86% 18%,rgba(0,176,255,.20),transparent 32%),linear-gradient(140deg,#041126 0%,#071d3b 46%,#0a2550 100%);color:#e9f3ff}
.student-shell{padding:2.2rem 0 3rem}.student-title{font-size:clamp(2rem,4vw,3.2rem);font-weight:800;color:#f4f9ff}.back-btn{border-radius:12px;border:1px solid rgba(145,198,255,.5);background:rgba(10,31,70,.4);color:#deeeff;padding:.7rem 1.2rem}
.grid-main{display:grid;grid-template-columns:2fr 1fr;gap:1rem}.card-glass{background:linear-gradient(140deg,rgba(250,252,255,.95),rgba(228,238,255,.93));color:#122849;border:1px solid rgba(255,255,255,.4);box-shadow:0 10px 28px rgba(2,17,45,.35);border-radius:20px}
.profile-card{padding:1.4rem}.profile-head{display:flex;justify-content:space-between;gap:1rem;align-items:center}.profile-user{display:flex;align-items:center;gap:.8rem}.avatar{width:72px;height:72px;border-radius:50%;object-fit:cover;border:3px solid rgba(31,102,226,.2)}
.name{margin:0;font-size:1.9rem;font-weight:800;color:#0b2347}.mail{margin:.1rem 0 0;color:#415978}.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}.form-grid .form-control,.form-grid .form-select{border-radius:10px;border:1px solid #c4d6f0}
.save-btn{margin-top:.85rem;border:0;border-radius:999px;font-weight:700;padding:.7rem 1.2rem;background:linear-gradient(120deg,#0e59f3,#0a8bff);color:#fff}
.side{background:linear-gradient(150deg,rgba(22,70,152,.97),rgba(8,38,88,.95));color:#e9f5ff;border-radius:20px;border:1px solid rgba(109,170,255,.32);padding:1.2rem}.kpi{font-size:2.2rem;font-weight:900;line-height:1}.chip{margin-top:.8rem;border-radius:14px;padding:.75rem;background:linear-gradient(140deg,rgba(16,90,192,.95),rgba(18,169,255,.8))}
.grid-w{margin-top:1rem;display:grid;grid-template-columns:1.1fr 1fr;gap:1rem}.w-dark,.w-light{border-radius:16px;box-shadow:0 8px 20px rgba(3,17,46,.25);padding:1rem}.w-dark{background:linear-gradient(150deg,rgba(10,51,124,.96),rgba(8,28,72,.93));color:#dcecff}.w-light{background:linear-gradient(140deg,rgba(250,252,255,.95),rgba(225,236,255,.93));color:#132847}
.w-title{margin:0;font-size:1.45rem;font-weight:800}.chart-wrap{height:220px}.insight{margin-top:.8rem;border-top:1px solid #d2deef;padding-top:.8rem;font-weight:700}
.lists{margin-top:1rem;display:grid;grid-template-columns:1fr 1fr;gap:1rem}.list-card{border-radius:16px;background:linear-gradient(140deg,rgba(246,250,255,.96),rgba(224,235,255,.93));color:#122849;box-shadow:0 10px 22px rgba(5,19,49,.25);padding:1rem}
.item-link{display:block;padding:.45rem .55rem;border-radius:10px;color:#0c2f62;text-decoration:none;font-weight:600}.item-link:hover{background:#e7f0ff;color:#0a4aa5}
.badge-soft{display:inline-block;border-radius:999px;padding:.13rem .55rem;font-size:.72rem;font-weight:800;background:#d9e7ff;color:#1d4d95}
@media (max-width:1200px){.grid-main,.grid-w,.lists{grid-template-columns:1fr}.profile-head{flex-direction:column;align-items:flex-start}}
@media (max-width:768px){.form-grid{grid-template-columns:1fr}}
</style>
{% endblock %}

{% block body %}
<section class="student-shell"><div class="container">
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3"><h1 class="student-title">My Student Profile</h1><div class="d-flex gap-2"><a href="{{ path('app_reclamation_index') }}" class="btn back-btn"><i class="fas fa-comment-dots me-2"></i>Reclamations</a><a href="{{ path('student_cours_index') }}" class="btn back-btn"><i class="fas fa-arrow-left me-2"></i>Back to courses</a></div></div>
{% for message in app.flashes('success') %}<div class="alert alert-success mt-2">{{ message }}</div>{% endfor %}

<div class="grid-main">
<div class="card-glass profile-card">
<div class="profile-head">
<div class="profile-user"><img src="{{ asset(user.image ? 'uploads/users/' ~ user.image : 'uploads/users/chat1.png') }}" class="avatar" alt="Profile"><div><p class="name">{{ user.nom ?: 'Student' }}</p><p class="mail">{{ user.email }}</p></div></div>
<div><div><i class="fas fa-graduation-cap me-1"></i>Estimated progress <strong id="progressValue">{{ aiInsights.estimated_progress|default(0)|number_format(1, '.', '') }}%</strong></div><div id="apiStatus" class="small mt-1">Learning API sync ready</div></div>
</div>
{{ form_start(form) }}<div class="form-grid">{{ form_row(form.nom) }}{{ form_row(form.email) }}{{ form_row(form.plainPassword) }}{{ form_row(form.image) }}</div><button type="submit" class="save-btn"><i class="fas fa-floppy-disk me-2"></i>Save profile</button>{{ form_end(form) }}
</div>
<div class="side">
<div class="d-flex justify-content-between align-items-center"><strong>Learning KPIs</strong><span class="badge text-bg-info">Live</span></div>
<div class="mt-3"><div class="small">Courses</div><div class="kpi" id="coursesCount">{{ coursesCount }}</div></div>
<div class="mt-2"><div class="small">Quizzes</div><div class="kpi" id="quizzesCount">{{ quizzesCount }}</div></div>
<div class="chip mt-3"><i class="fas fa-brain me-2"></i>AI tutor insights + API student resume</div>
<div class="mt-2 small" id="summaryText">{{ aiInsights.ai_summary|default('No summary available.') }}</div>
</div>
</div>

<div class="grid-w">
<div class="w-dark"><div class="d-flex justify-content-between"><h3 class="w-title">Course & Quiz Trend</h3><small>Overview</small></div><div class="chart-wrap"><canvas id="studentChart"></canvas></div></div>
<div class="w-light"><div class="d-flex justify-content-between align-items-center"><h3 class="w-title">AI Learning Insights</h3><span class="badge-soft">Student AI</span></div><div class="mt-3"><div><strong>Average quiz points:</strong> <span id="avgPoints">{{ aiInsights.avg_quiz_points|default(0)|number_format(2, '.', '') }}</span></div><div><strong>Video share:</strong> <span id="videoShare">0%</span></div></div><div id="insightMsg" class="insight">{{ aiInsights.recommendations[0]|default('Keep a consistent study rhythm this week.') }}</div></div>
</div>

<div class="lists">
<div class="list-card"><h3 class="h5 mb-3">Latest Courses</h3>
{% for course in latestCourses %}
    <a class="item-link" href="{{ path('student_cours_show', {'id': course.id}) }}"><span class="badge-soft me-2">{{ course.typeMedia ?: 'MEDIA' }}</span>{{ course.titre }}</a>
{% else %}
    <p class="text-muted mb-0">No courses available.</p>
{% endfor %}
</div>
<div class="list-card"><h3 class="h5 mb-3">Latest Quizzes</h3>
{% for quiz in latestQuizzes %}
    <a class="item-link" href="{{ path('student_quiz_show', {'id': quiz.id}) }}"><span class="badge-soft me-2">{{ quiz.pointsValeur ?: 0 }} pts</span>{{ quiz.question|slice(0, 80) }}</a>
{% else %}
    <p class="text-muted mb-0">No quizzes available.</p>
{% endfor %}
</div>
</div>

</div></section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script>
(function(){
const apiUrl=`{{ path('api_student_profile_resume', {'id': user.id}) }}`;
const initialAi={{ aiInsights|json_encode|raw }};
const cCourses=document.getElementById('coursesCount');
const cQuizzes=document.getElementById('quizzesCount');
const cProgress=document.getElementById('progressValue');
const cSummary=document.getElementById('summaryText');
const cApi=document.getElementById('apiStatus');
const cAvg=document.getElementById('avgPoints');
const cVideo=document.getElementById('videoShare');
const cMsg=document.getElementById('insightMsg');

function renderInsights(ins){
  const media=ins.media_breakdown||{};
  const total=(media.VIDEO||0)+(media.TEXT||0)+(media.OTHER||0);
  const videoPct=total>0?((media.VIDEO||0)/total)*100:0;
  cAvg.textContent=Number(ins.avg_quiz_points||0).toFixed(2);
  cProgress.textContent=Number(ins.estimated_progress||0).toFixed(1)+'%';
  cSummary.textContent=ins.ai_summary||'No summary available.';
  cVideo.textContent=videoPct.toFixed(1)+'%';
  cMsg.textContent=(ins.recommendations&&ins.recommendations[0])?ins.recommendations[0]:'Keep a consistent study rhythm this week.';
}

function buildChart(ins){
  const media=ins.media_breakdown||{};
  new Chart(document.getElementById('studentChart'),{
    type:'bar',
    data:{labels:['Video courses','Text courses','Other media','Total quizzes'],datasets:[{data:[media.VIDEO||0,media.TEXT||0,media.OTHER||0,ins.total_quizzes||0],backgroundColor:['#39b8ff','#4b7dff','#8aa8ff','#2ed6b3'],borderRadius:8}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#d0e5ff'},grid:{color:'rgba(137,186,255,.18)'}},y:{ticks:{color:'#d0e5ff'},grid:{color:'rgba(137,186,255,.2)'}}}}
  });
}

renderInsights(initialAi);
buildChart(initialAi);

fetch(apiUrl,{headers:{Accept:'application/json'}}).then(r=>r.json()).then(data=>{
  if(!data.success){throw new Error('api');}
  cCourses.textContent=data.courses_count;
  cQuizzes.textContent=data.quizzes_count;
  renderInsights(data.ai_insights||initialAi);
  cApi.textContent='Learning API synced';
}).catch(()=>{cApi.textContent='API unavailable, fallback mode';});
})();
</script>
{% endblock %}
