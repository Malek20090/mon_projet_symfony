{% extends 'base_pages.html.twig' %}

{% block title %}Passer le Quiz | Decide${% endblock %}

{% block body_class %}alea-page learning-page{% endblock %}

{% block body %}
    <!-- Hero quiz -->
    <section class="hero">
        <div class="container text-center wrap">
            <div class="learning-hero-tag">
                <i class="fas fa-bolt"></i> Challenge en direct
            </div>
            <h1>Take quiz</h1>
            <p>Answer the questions and instantly see your score.</p>
            <div class="breadcrumbs">
                <a href="{{ path('app_home') }}">Home</a> /
                <a href="{{ path('app_service') }}">Modules</a> /
                <a href="{{ path('student_quiz_index') }}">Quiz</a> /
                <span class="active">Take quiz</span>
            </div>
        </div>
    </section>

    <section class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="{{ path('student_cours_index') }}">Home</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('student_quiz_index') }}">Quiz</a></li>
                        <li class="breadcrumb-item active">Take quiz</li>
                    </ol>
                </nav>

                {% if score is null %}
                    <!-- Formulaire du quiz -->
                    <div class="card shadow quiz-pass-card">
                        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                            <div>
                                <h3 class="mb-0">
                                    <i class="fas fa-question-circle"></i> Quiz
                                </h3>
                                {% if quiz.cours %}
                                    <small class="text-white-50">
                                        <i class="fas fa-book me-1"></i> {{ quiz.cours.titre }}
                                    </small>
                                {% endif %}
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="badge bg-warning text-dark me-3">
                                    <i class="fas fa-star me-1"></i>{{ quiz.pointsValeur }} points
                                </span>
                                <div class="timer-badge" id="timerBadge">
                                    <i class="fas fa-clock me-1"></i>
                                    <span id="timerCountdown">30</span>s
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="question-section mb-4">
                                <div class="d-flex align-items-start">
                                    <h4 class="text-dark mb-0 flex-grow-1">
                                        <i class="fas fa-question text-primary"></i> {{ quiz.question }}
                                    </h4>
                                    <button type="button" class="btn btn-outline-primary btn-sm rounded-circle ms-2" onclick="speakQuestion()" title="Écouter la question" id="speakBtn">
                                        <i class="fas fa-volume-up" id="speakIcon"></i>
                                    </button>
                                </div>
                            </div>

                            <form method="POST" action="{{ path('student_quiz_pass', {'id': quiz.id}) }}" id="quizForm" data-turbo="false">
                                <div class="choices-section">
                                    {% for choix in quiz.choixReponses %}
                                        <div class="form-check mb-3 p-3 border rounded choice-option">
                                            <input class="form-check-input" type="radio" name="reponse" id="choice{{ loop.index0 }}" value="{{ choix }}" required>
                                            <label class="form-check-label w-100" for="choice{{ loop.index0 }}">
                                                <strong>{{ loop.index0 == 0 ? 'A' : (loop.index0 == 1 ? 'B' : (loop.index0 == 2 ? 'C' : 'D')) }}.</strong> {{ choix }}
                                            </label>
                                        </div>
                                    {% endfor %}
                                </div>

                                <div class="d-grid gap-2 mt-4">
                                    <button type="submit" class="btn btn-primary btn-lg rounded-pill" id="submitBtn">
                                        <span class="btn-content">
                                            <i class="fas fa-paper-plane"></i> Submit my answer
                                        </span>
                                        <span class="btn-loading" style="display: none;">
                                            <i class="fas fa-spinner fa-spin"></i> Checking...
                                        </span>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                {% else %}
                    <!-- Results du quiz -->
                    <div class="card shadow quiz-result-card {% if isCorrect %}border-success{% else %}border-danger{% endif %}">
                        <div class="card-header {% if isCorrect %}bg-success{% else %}bg-danger{% endif %} text-white">
                            <h3 class="mb-0">
                                <i class="fas fa-{% if isCorrect %}check-circle{% else %}times-circle{% endif %}"></i>
                                Result du Quiz
                            </h3>
                        </div>
                        <div class="card-body text-center">
                            <div class="result-icon mb-4">
                                {% if isCorrect %}
                                    <i class="fas fa-check-circle fa-5x text-success"></i>
                                    <h2 class="text-success mt-3">Bravo ! Correct answer</h2>
                                {% elseif previousResult.timeOut is defined and previousResult.timeOut %}
                                    <i class="fas fa-clock fa-5x text-warning"></i>
                                    <h2 class="text-warning mt-3">Temps écoulé !</h2>
                                {% else %}
                                    <i class="fas fa-times-circle fa-5x text-danger"></i>
                                    <h2 class="text-danger mt-3">Incorrect answer</h2>
                                {% endif %}
                            </div>

                            <div class="question-section mb-4">
                                <h5 class="text-dark mb-3">{{ quiz.question }}</h5>
                            </div>

                            <div class="answer-section mb-4">
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <div class="p-3 border rounded text-start">
                                            <strong class="text-muted d-block mb-2">Your answer:</strong>
                                            <span class="badge bg-{% if isCorrect %}success{% else %}danger{% endif %} fs-6 py-2 px-3 d-block text-wrap">
                                                {{ reponseUtilisateur }}
                                            </span>
                                        </div>
                                    </div>
                                    <div class="col-12 mb-3">
                                        <div class="p-3 border rounded text-start">
                                            <strong class="text-muted d-block mb-2">Correct answer:</strong>
                                            <span class="badge bg-success fs-6 py-2 px-3 d-block text-wrap">
                                                {{ quiz.reponseCorrecte }}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="score-section mb-4">
                                <div class="alert {% if isCorrect %}alert-success{% else %}alert-danger{% endif %}">
                                    <h4 class="mb-0">
                                        <i class="fas fa-star"></i> Score : {{ score }} / {{ quiz.pointsValeur }} points
                                    </h4>
                                </div>
                            </div>

                            <div class="actions-section">
                                {% if quiz.cours %}
                                    <a href="{{ path('student_cours_show', {'id': quiz.cours.id}) }}" class="btn btn-primary me-2 rounded-pill">
                                        <i class="fas fa-book"></i> Back to course
                                    </a>
                                {% endif %}
                                <a href="{{ path('student_quiz_pass', {'id': quiz.id}) }}" class="btn btn-outline-primary me-2 rounded-pill">
                                    <i class="fas fa-redo"></i> Try again
                                </a>
                                <a href="{{ path('student_quiz_index') }}" class="btn btn-secondary rounded-pill">
                                    <i class="fas fa-list"></i> Other quizzes
                                </a>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>

    <style>
        .quiz-pass-card,
        .quiz-result-card {
            border-radius: 18px;
            overflow: hidden;
        }

        .choice-option {
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .choice-option:hover {
            background-color: #f8f9fa;
            border-color: #1e3fa3 !important;
            transform: translateX(5px);
        }

        .choice-option input[type="radio"]:checked + label {
            color: #1e3fa3;
            font-weight: bold;
        }

        .choice-option:has(input[type="radio"]:checked) {
            background-color: #e7f3ff;
            border-color: #1e3fa3 !important;
        }

        .timer-badge {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 8px 16px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
            animation: pulse 2s infinite;
        }

        .timer-badge.warning {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            animation: shake 0.5s infinite;
        }

        .timer-badge.danger {
            background: linear-gradient(135deg, #fa709a 0%, #ee0979 100%);
            animation: shake 0.3s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-3px); }
            75% { transform: translateX(3px); }
        }
    </style>

    <script>
        // Text-to-Speech function
        function speakQuestion() {
            // Get the question text from the data attribute (cleaner than parsing DOM)
            const questionElement = document.querySelector('.question-section h4');
            let questionText = questionElement.textContent.replace(/question/gi, '').trim();
            
            const speakBtn = document.getElementById('speakBtn');
            const speakIcon = document.getElementById('speakIcon');
            
            // Check if speech synthesis is supported
            if ('speechSynthesis' in window) {
                // Cancel any ongoing speech
                window.speechSynthesis.cancel();
                
                const utterance = new SpeechSynthesisUtterance(questionText);
                utterance.lang = 'fr-FR'; // French
                utterance.rate = 0.9; // Slightly slower for clarity
                utterance.pitch = 1;
                
                // Change icon while speaking
                utterance.onstart = function() {
                    speakIcon.classList.remove('fa-volume-up');
                    speakIcon.classList.add('fa-volume-up');
                    speakBtn.classList.add('btn-primary');
                    speakBtn.classList.remove('btn-outline-primary');
                };
                
                utterance.onend = function() {
                    speakIcon.classList.remove('fa-volume-up');
                    speakIcon.classList.add('fa-volume-up');
                    speakBtn.classList.remove('btn-primary');
                    speakBtn.classList.add('btn-outline-primary');
                };
                
                window.speechSynthesis.speak(utterance);
            } else {
                alert('Votre navigateur ne supporte pas la synthèse vocale.');
            }
        }
        
        // Start timer immediately, don't wait for DOMContentLoaded
        (function() {
            const form = document.getElementById('quizForm');
            const submitBtn = document.getElementById('submitBtn');
            const timerBadge = document.getElementById('timerBadge');
            const timerCountdown = document.getElementById('timerCountdown');
            
            // Timer configuration
            const TIMER_DURATION = 30;
            let timeLeft = TIMER_DURATION;
            let timerInterval = null;
            
            // Timer function
            function startTimer() {
                if (!form || !timerBadge || !timerCountdown) return;
                
                // Reset timer to full duration
                timeLeft = TIMER_DURATION;
                timerCountdown.textContent = timeLeft;
                timerBadge.classList.remove('warning', 'danger');
                
                timerInterval = setInterval(function() {
                    timeLeft--;
                    timerCountdown.textContent = timeLeft;
                    
                    // Update timer badge style based on time remaining
                    if (timeLeft <= 10) {
                        timerBadge.classList.add('danger');
                        timerBadge.classList.remove('warning');
                    } else if (timeLeft <= 20) {
                        timerBadge.classList.add('warning');
                    }
                    
                    // Time's up - submit the form automatically
                    if (timeLeft <= 0) {
                        clearInterval(timerInterval);
                        
                        // Disable all inputs
                        const inputs = form.querySelectorAll('input[type="radio"]');
                        inputs.forEach(function(input) {
                            input.disabled = true;
                        });
                        submitBtn.disabled = true;
                        
                        // Auto-submit the form with empty answer (will be marked as incorrect)
                        form.submit();
                    }
                }, 1000);
            }
            
            // Start timer immediately if elements exist
            if (form && timerBadge && timerCountdown) {
                startTimer();
            }
            
            // Handle page show event (bfcache)
            window.addEventListener('pageshow', function(event) {
                if (event.persisted) {
                    // Page was loaded from bfcache, restart timer
                    if (timerInterval) clearInterval(timerInterval);
                    startTimer();
                }
            });
            
            if (form && submitBtn) {
                form.addEventListener('submit', function(e) {
                    // Clear timer on submit
                    if (timerInterval) {
                        clearInterval(timerInterval);
                    }
                    
                    // Show loading state
                    const btnContent = submitBtn.querySelector('.btn-content');
                    const btnLoading = submitBtn.querySelector('.btn-loading');
                    
                    if (btnContent && btnLoading) {
                        btnContent.style.display = 'none';
                        btnLoading.style.display = 'inline';
                    }
                    
                    // Disable button to prevent double submission
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-75');
                });
            }
        })();
    </script>
{% endblock %}



