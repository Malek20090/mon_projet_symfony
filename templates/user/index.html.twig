{% extends 'admin/layout.html.twig' %}

{% block title %}Users | Decide${% endblock %}

{% block content %}
<div class="admin-page">
    <div class="page-header-card">
        <div>
            <h1>Users</h1>
            <p class="mb-0">Manage admin and user accounts from one workspace</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            {% if current_admin_id %}
                <a href="{{ path('app_user_show', {'id': current_admin_id}) }}" class="btn btn-outline-primary">
                    <i class="fas fa-user-shield me-2"></i>My profile
                </a>
                <a href="{{ path('app_user_edit', {'id': current_admin_id}) }}" class="btn btn-primary">
                    <i class="fas fa-pen-to-square me-2"></i>Edit my profile
                </a>
            {% endif %}
            <a href="{{ path('app_user_new') }}" class="btn btn-success">
                <i class="fas fa-user-plus me-2"></i>Add user
            </a>
        </div>
    </div>

    <div class="card-custom mb-3">
        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
            <h5 class="mb-0"><i class="fas fa-filter text-primary me-2"></i>Search & Sort</h5>
            <a href="{{ path('app_user_index') }}" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-rotate-left me-1"></i>Reset
            </a>
        </div>

        <form method="get" class="row g-2">
            <div class="col-md-4">
                <input
                    type="text"
                    name="q"
                    class="form-control"
                    placeholder="Search by name or email"
                    value="{{ filter_q|default('') }}"
                >
            </div>
            <div class="col-md-3">
                <select name="role" class="form-select">
                    <option value="" {{ (filter_role|default('')) == '' ? 'selected' : '' }}>All roles</option>
                    <option value="ROLE_ADMIN" {{ (filter_role|default('')) == 'ROLE_ADMIN' ? 'selected' : '' }}>Admin</option>
                    <option value="ROLE_SALARY" {{ (filter_role|default('')) == 'ROLE_SALARY' ? 'selected' : '' }}>Salary</option>
                    <option value="ROLE_ETUDIANT" {{ (filter_role|default('')) == 'ROLE_ETUDIANT' ? 'selected' : '' }}>Student</option>
                    <option value="ROLE_USER_ONLY" {{ (filter_role|default('')) == 'ROLE_USER_ONLY' ? 'selected' : '' }}>Standard user</option>
                </select>
            </div>
            <div class="col-md-3">
                <select name="sort" class="form-select">
                    <option value="nom" {{ (filter_sort|default('nom')) == 'nom' ? 'selected' : '' }}>Sort by name</option>
                    <option value="email" {{ (filter_sort|default('nom')) == 'email' ? 'selected' : '' }}>Sort by email</option>
                    <option value="solde" {{ (filter_sort|default('nom')) == 'solde' ? 'selected' : '' }}>Sort by balance</option>
                    <option value="date" {{ (filter_sort|default('nom')) == 'date' ? 'selected' : '' }}>Sort by registration date</option>
                    <option value="id" {{ (filter_sort|default('nom')) == 'id' ? 'selected' : '' }}>Sort by ID</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="order" class="form-select">
                    <option value="ASC" {{ (filter_order|default('ASC')) == 'ASC' ? 'selected' : '' }}>ASC</option>
                    <option value="DESC" {{ (filter_order|default('ASC')) == 'DESC' ? 'selected' : '' }}>DESC</option>
                </select>
            </div>
            <div class="col-12 d-flex justify-content-end">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search me-1"></i>Apply
                </button>
            </div>
        </form>
    </div>

    <div class="card-custom mb-3">
        <h5 class="mb-3"><i class="fas fa-user-shield text-primary me-2"></i>Administrators</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Balance</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for admin in admins %}
                        <tr>
                            <td>
                                <div class="user-name-cell">
                                    <img
                                        src="{{ asset(admin.image ? 'uploads/users/' ~ admin.image : 'uploads/users/chat1.png') }}"
                                        alt="{{ admin.nom ?: 'User' }}"
                                        class="user-list-avatar"
                                    >
                                    <span>{{ admin.nom ?: '-' }}</span>
                                </div>
                            </td>
                            <td>{{ admin.email }}</td>
                            <td><span class="badge badge-admin">Admin</span></td>
                            <td>{{ admin.soldeTotal|number_format(2, '.', ' ') }} TND</td>
                            <td>
                                <a href="{{ path('app_user_show', {'id': admin.id}) }}" class="btn btn-sm btn-outline-primary">Show</a>
                                <a href="{{ path('app_user_edit', {'id': admin.id}) }}" class="btn btn-sm btn-primary">Edit</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">No administrator found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-custom">
        <h5 class="mb-3"><i class="fas fa-users text-primary me-2"></i>Users</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Balance</th>
                        <th style="width: 220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td>
                                <div class="user-name-cell">
                                    <img
                                        src="{{ asset(user.image ? 'uploads/users/' ~ user.image : 'uploads/users/chat1.png') }}"
                                        alt="{{ user.nom ?: 'User' }}"
                                        class="user-list-avatar"
                                    >
                                    <span>{{ user.nom ?: '-' }}</span>
                                </div>
                            </td>
                            <td>{{ user.email }}</td>
                            <td>
                                {% if 'ROLE_SALARY' in user.roles %}
                                    <span class="badge badge-salary">Salary</span>
                                {% elseif 'ROLE_ETUDIANT' in user.roles %}
                                    <span class="badge badge-student">Student</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ user.roles|join(', ') ?: 'User' }}</span>
                                {% endif %}
                            </td>
                            <td>{{ user.soldeTotal|number_format(2, '.', ' ') }} TND</td>
                            <td>
                                <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary">Show</a>
                                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-sm btn-primary">Edit</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted py-3">No user found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
